<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Color x:Key="Color.AppBackground">#111827</Color>
  <Color x:Key="Color.TopBar">#0B1220</Color>
  <Color x:Key="Color.SideNav">#111827</Color>
  <Color x:Key="Color.Workspace">#1F2937</Color>
  <Color x:Key="Color.EventLog">#0F172A</Color>
  <Color x:Key="Color.Card">#273449</Color>
  <Color x:Key="Color.CardBorder">#3B4A63</Color>
  <Color x:Key="Color.TextPrimary">#F9FAFB</Color>
  <Color x:Key="Color.TextSecondary">#CBD5E1</Color>
  <Color x:Key="Color.TextMuted">#94A3B8</Color>
  <Color x:Key="Color.Ready">#22C55E</Color>
  <Color x:Key="Color.Warning">#F59E0B</Color>
  <Color x:Key="Color.Alarm">#EF4444</Color>
  <Color x:Key="Color.Moving">#3B82F6</Color>
  <Color x:Key="Color.Disabled">#6B7280</Color>
  <Color x:Key="Color.NavSelected">#334155</Color>
  <Color x:Key="Color.PanelAlt">#1E293B</Color>

  <SolidColorBrush x:Key="Brush.AppBackground" Color="{StaticResource Color.AppBackground}" />
  <SolidColorBrush x:Key="Brush.TopBar" Color="{StaticResource Color.TopBar}" />
  <SolidColorBrush x:Key="Brush.SideNav" Color="{StaticResource Color.SideNav}" />
  <SolidColorBrush x:Key="Brush.Workspace" Color="{StaticResource Color.Workspace}" />
  <SolidColorBrush x:Key="Brush.EventLog" Color="{StaticResource Color.EventLog}" />
  <SolidColorBrush x:Key="Brush.Card" Color="{StaticResource Color.Card}" />
  <SolidColorBrush x:Key="Brush.CardBorder" Color="{StaticResource Color.CardBorder}" />
  <SolidColorBrush x:Key="Brush.TextPrimary" Color="{StaticResource Color.TextPrimary}" />
  <SolidColorBrush x:Key="Brush.TextSecondary" Color="{StaticResource Color.TextSecondary}" />
  <SolidColorBrush x:Key="Brush.TextMuted" Color="{StaticResource Color.TextMuted}" />
  <SolidColorBrush x:Key="Brush.Ready" Color="{StaticResource Color.Ready}" />
  <SolidColorBrush x:Key="Brush.Warning" Color="{StaticResource Color.Warning}" />
  <SolidColorBrush x:Key="Brush.Alarm" Color="{StaticResource Color.Alarm}" />
  <SolidColorBrush x:Key="Brush.Moving" Color="{StaticResource Color.Moving}" />
  <SolidColorBrush x:Key="Brush.Disabled" Color="{StaticResource Color.Disabled}" />
  <SolidColorBrush x:Key="Brush.NavSelected" Color="{StaticResource Color.NavSelected}" />
  <SolidColorBrush x:Key="Brush.PanelAlt" Color="{StaticResource Color.PanelAlt}" />
</ResourceDictionary>
