<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Style x:Key="Text.Logo" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
    <Setter Property="FontSize" Value="22" />
    <Setter Property="FontWeight" Value="Bold" />
  </Style>

  <Style x:Key="Text.Status" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}" />
    <Setter Property="FontSize" Value="14" />
  </Style>

  <Style x:Key="Text.StatusStrong" TargetType="TextBlock" BasedOn="{StaticResource Text.Status}">
    <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style x:Key="Text.SectionHeader" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style x:Key="Text.PageTitle" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
    <Setter Property="FontSize" Value="28" />
    <Setter Property="FontWeight" Value="Bold" />
  </Style>

  <Style x:Key="Text.CardTitle" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
    <Setter Property="FontSize" Value="16" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Margin" Value="0,0,0,10" />
  </Style>

  <Style x:Key="Text.MetricLabel" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}" />
    <Setter Property="FontSize" Value="12" />
  </Style>

  <Style x:Key="Text.MetricValue" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
    <Setter Property="FontSize" Value="18" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style x:Key="Text.PillLabel" TargetType="TextBlock">
    <Setter Property="Foreground" Value="White" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Opacity" Value="0.85" />
  </Style>

  <Style x:Key="Text.PillValue" TargetType="TextBlock">
    <Setter Property="Foreground" Value="White" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="Bold" />
  </Style>

  <Style x:Key="Form.Field" TargetType="StackPanel">
    <Setter Property="Margin" Value="0,0,12,8" />
  </Style>

  <Style x:Key="TextBox.HmiInput" TargetType="TextBox">
    <Setter Property="Height" Value="32" />
    <Setter Property="MinWidth" Value="72" />
  </Style>

  <Style x:Key="ComboBox.HmiInput" TargetType="ComboBox">
    <Setter Property="Height" Value="32" />
    <Setter Property="MinWidth" Value="88" />
  </Style>

  <Style x:Key="Button.HmiCommand" TargetType="Button">
    <Setter Property="Height" Value="36" />
    <Setter Property="MinWidth" Value="96" />
    <Setter Property="Margin" Value="0,0,8,8" />
  </Style>

  <Style x:Key="Button.HmiCommand.Compact" TargetType="Button" BasedOn="{StaticResource Button.HmiCommand}">
    <Setter Property="Height" Value="32" />
    <Setter Property="MinWidth" Value="84" />
  </Style>

  <Style x:Key="ListView.HmiGrid" TargetType="ListView">
    <Setter Property="Background" Value="{DynamicResource Brush.PanelAlt}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
    <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
    <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
  </Style>

  <Style x:Key="TopBar.StatusChip" TargetType="Border">
    <Setter Property="Background" Value="{DynamicResource Brush.PanelAlt}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.CardBorder}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="10,4" />
    <Setter Property="Margin" Value="6,0,0,0" />
    <Setter Property="MinWidth" Value="108" />
    <Setter Property="MaxWidth" Value="240" />
    <Setter Property="Height" Value="42" />
  </Style>

  <Style x:Key="Text.TopBarLabel" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style x:Key="Text.TopBarValue" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
  </Style>

  <Style x:Key="DataGridColumnHeader.Hmi" TargetType="DataGridColumnHeader">
    <Setter Property="Background" Value="{DynamicResource Brush.PanelAlt}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Padding" Value="8,6" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.CardBorder}" />
    <Setter Property="BorderThickness" Value="0,0,1,1" />
  </Style>

  <Style x:Key="DataGridCell.Hmi" TargetType="DataGridCell">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.CardBorder}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
  </Style>

  <Style x:Key="DataGridRow.Hmi" TargetType="DataGridRow">
    <Setter Property="MinHeight" Value="28" />
    <Setter Property="Background" Value="{DynamicResource Brush.EventLog}" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
  </Style>

  <Style x:Key="DataGrid.HmiGrid" TargetType="DataGrid">
    <Setter Property="AutoGenerateColumns" Value="False" />
    <Setter Property="CanUserAddRows" Value="False" />
    <Setter Property="CanUserDeleteRows" Value="False" />
    <Setter Property="CanUserReorderColumns" Value="False" />
    <Setter Property="CanUserResizeRows" Value="False" />
    <Setter Property="HeadersVisibility" Value="Column" />
    <Setter Property="IsReadOnly" Value="True" />
    <Setter Property="RowHeaderWidth" Value="0" />
    <Setter Property="Background" Value="{DynamicResource Brush.EventLog}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
    <Setter Property="GridLinesVisibility" Value="Horizontal" />
    <Setter Property="AlternatingRowBackground" Value="{DynamicResource Brush.PanelAlt}" />
    <Setter Property="AlternationCount" Value="2" />
    <Setter Property="ColumnHeaderStyle" Value="{StaticResource DataGridColumnHeader.Hmi}" />
    <Setter Property="CellStyle" Value="{StaticResource DataGridCell.Hmi}" />
    <Setter Property="RowStyle" Value="{StaticResource DataGridRow.Hmi}" />
    <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
    <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
  </Style>

  <Style x:Key="Button.Nav" TargetType="Button">
    <Setter Property="Height" Value="40" />
    <Setter Property="Margin" Value="0,4" />
    <Setter Property="HorizontalContentAlignment" Value="Left" />
    <Setter Property="Padding" Value="14,0" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Style.Triggers>
      <DataTrigger Binding="{Binding IsSelected}" Value="True">
        <Setter Property="Background" Value="{DynamicResource Brush.NavSelected}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
      </DataTrigger>
    </Style.Triggers>
  </Style>

  <Style x:Key="Card.Panel" TargetType="Border">
    <Setter Property="Background" Value="{DynamicResource Brush.Card}" />
    <Setter Property="BorderBrush" Value="{DynamicResource Brush.CardBorder}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Margin" Value="8" />
    <Setter Property="Padding" Value="14" />
  </Style>

  <Style x:Key="Card.Compact" TargetType="Border" BasedOn="{StaticResource Card.Panel}">
    <Setter Property="Margin" Value="4" />
    <Setter Property="Padding" Value="10" />
  </Style>
</ResourceDictionary>
