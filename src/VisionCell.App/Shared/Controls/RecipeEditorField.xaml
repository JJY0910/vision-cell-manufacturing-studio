<UserControl x:Class="VisionCell.App.Shared.Controls.RecipeEditorField"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             ToolTip="{Binding HelpText, ElementName=Root}">
  <StackPanel Width="{Binding FieldWidth, ElementName=Root}">
    <TextBlock Text="{Binding Label, ElementName=Root}"
               Style="{DynamicResource Text.MetricLabel}" />
    <TextBox Text="{Binding Text, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
             IsReadOnly="{Binding IsReadOnly, ElementName=Root}"
             Style="{DynamicResource TextBox.HmiInput}"
             AutomationProperties.Name="{Binding Label, ElementName=Root}" />
  </StackPanel>
</UserControl>
