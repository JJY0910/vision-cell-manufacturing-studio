<UserControl x:Class="VisionCell.App.Shared.Controls.ErrorBanner"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
  <UserControl.Style>
    <Style TargetType="UserControl">
      <Setter Property="Visibility" Value="Collapsed" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsOpen, ElementName=Root}" Value="True">
          <Setter Property="Visibility" Value="Visible" />
        </DataTrigger>
      </Style.Triggers>
    </Style>
  </UserControl.Style>
  <Border Background="{DynamicResource Brush.Alarm}"
          CornerRadius="8"
          Padding="12,8"
          MinHeight="42"
          ToolTip="{Binding Message, ElementName=Root}">
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <TextBlock Text="{Binding Title, ElementName=Root}"
                 Foreground="White"
                 FontSize="12"
                 FontWeight="SemiBold"
                 Margin="0,0,12,0" />
      <TextBlock Grid.Column="1"
                 Text="{Binding Message, ElementName=Root}"
                 Foreground="White"
                 FontSize="13"
                 FontWeight="SemiBold"
                 TextWrapping="Wrap" />
    </Grid>
  </Border>
</UserControl>
