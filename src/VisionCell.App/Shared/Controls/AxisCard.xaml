<UserControl x:Class="VisionCell.App.Shared.Controls.AxisCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Border Style="{DynamicResource Card.Compact}"
          MinHeight="150"
          ToolTip="{Binding Alarm}">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <DockPanel>
        <TextBlock Text="{Binding Label}"
                   Style="{DynamicResource Text.MetricValue}" />
        <TextBlock DockPanel.Dock="Right"
                   Text="{Binding MotionState}"
                   Style="{DynamicResource Text.StatusStrong}"
                   TextAlignment="Right" />
      </DockPanel>
      <UniformGrid Grid.Row="1" Columns="2" Margin="0,10,0,0">
        <StackPanel Margin="0,0,8,0">
          <TextBlock Text="Position" Style="{DynamicResource Text.MetricLabel}" />
          <TextBlock Text="{Binding PositionText}"
                     Style="{DynamicResource Text.StatusStrong}"
                     TextWrapping="Wrap" />
        </StackPanel>
        <StackPanel>
          <TextBlock Text="Target" Style="{DynamicResource Text.MetricLabel}" />
          <TextBlock Text="{Binding TargetText}"
                     Style="{DynamicResource Text.StatusStrong}"
                     TextWrapping="Wrap" />
        </StackPanel>
      </UniformGrid>
      <TextBlock Grid.Row="2"
                 Text="{Binding SoftLimitText}"
                 Style="{DynamicResource Text.MetricLabel}"
                 TextWrapping="Wrap"
                 Margin="0,10,0,0" />
      <WrapPanel Grid.Row="3" Margin="0,8,0,0">
        <TextBlock Text="{Binding HomeState}"
                   Style="{DynamicResource Text.MetricLabel}"
                   Margin="0,0,12,0" />
        <TextBlock Text="{Binding ServoState}"
                   Style="{DynamicResource Text.MetricLabel}"
                   Margin="0,0,12,0" />
        <TextBlock Text="{Binding Alarm, StringFormat=Alarm {0}}"
                   Style="{DynamicResource Text.MetricLabel}" />
      </WrapPanel>
    </Grid>
  </Border>
</UserControl>
