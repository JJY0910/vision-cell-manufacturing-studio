<UserControl x:Class="VisionCell.App.Shared.Controls.CommandBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:VisionCell.App.Shared.Controls"
             x:Name="Root">
  <DockPanel>
    <ContentPresenter DockPanel.Dock="Right"
                      Content="{Binding CommandContent, ElementName=Root}"
                      HorizontalAlignment="Right"
                      Margin="12,0,0,0" />
    <StackPanel>
      <TextBlock Text="{Binding Title, ElementName=Root}"
                 Style="{DynamicResource Text.PageTitle}" />
      <TextBlock Text="{Binding StatusText, ElementName=Root}"
                 Style="{DynamicResource Text.Status}"
                 TextWrapping="Wrap"
                 Margin="0,4,0,0" />
      <controls:ErrorBanner Message="{Binding AlertMessage, ElementName=Root}"
                            IsOpen="{Binding HasAlert, ElementName=Root}"
                            Margin="0,8,0,0" />
    </StackPanel>
  </DockPanel>
</UserControl>
