<UserControl x:Class="VisionCell.App.Shared.Controls.EmptyState"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
  <UserControl.Style>
    <Style TargetType="UserControl">
      <Setter Property="Visibility" Value="Visible" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding HasItems, ElementName=Root}" Value="True">
          <Setter Property="Visibility" Value="Collapsed" />
        </DataTrigger>
      </Style.Triggers>
    </Style>
  </UserControl.Style>
  <Border Background="{DynamicResource Brush.PanelAlt}"
          BorderBrush="{DynamicResource Brush.CardBorder}"
          BorderThickness="1"
          CornerRadius="8"
          Padding="16"
          MinHeight="76"
          ToolTip="{Binding Detail, ElementName=Root}">
    <StackPanel>
      <TextBlock Text="{Binding Title, ElementName=Root}"
                 Style="{DynamicResource Text.EmptyStateTitle}" />
      <TextBlock Text="{Binding Detail, ElementName=Root}"
                 Style="{DynamicResource Text.EmptyStateDetail}" />
    </StackPanel>
  </Border>
</UserControl>
