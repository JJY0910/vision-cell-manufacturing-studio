<UserControl x:Class="VisionCell.App.Shared.Controls.IoBitIndicator"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <UserControl.ToolTip>
    <StackPanel>
      <TextBlock Text="{Binding Name}" Style="{DynamicResource Text.StatusStrong}" />
      <TextBlock Text="{Binding Address, StringFormat=Address {0}}" Style="{DynamicResource Text.Status}" />
      <TextBlock Text="{Binding Direction, StringFormat=Direction {0}}" Style="{DynamicResource Text.Status}" />
    </StackPanel>
  </UserControl.ToolTip>
  <Border MinWidth="100"
          Height="28"
          CornerRadius="6"
          BorderBrush="{DynamicResource Brush.CardBorder}"
          BorderThickness="1"
          Background="{DynamicResource Brush.EventLog}"
          Padding="8,0">
    <DockPanel LastChildFill="False">
      <Ellipse Width="10"
               Height="10"
               StrokeThickness="2"
               Margin="0,0,8,0">
        <Ellipse.Style>
          <Style TargetType="Ellipse">
            <Setter Property="Fill" Value="{DynamicResource Brush.Disabled}" />
            <Setter Property="Stroke" Value="Transparent" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding Value}" Value="True">
                <Setter Property="Fill" Value="{DynamicResource Brush.Ready}" />
              </DataTrigger>
              <DataTrigger Binding="{Binding IsForced}" Value="True">
                <Setter Property="Stroke" Value="{DynamicResource Brush.Warning}" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Ellipse.Style>
      </Ellipse>
      <TextBlock VerticalAlignment="Center"
                 MinWidth="28">
        <TextBlock.Style>
          <Style TargetType="TextBlock" BasedOn="{StaticResource Text.StatusStrong}">
            <Setter Property="Text" Value="OFF" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding Value}" Value="True">
                <Setter Property="Text" Value="ON" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </TextBlock.Style>
      </TextBlock>
      <Border DockPanel.Dock="Right"
              CornerRadius="4"
              Background="{DynamicResource Brush.Warning}"
              Padding="6,1"
              Margin="8,0,0,0">
        <Border.Style>
          <Style TargetType="Border">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsForced}" Value="True">
                <Setter Property="Visibility" Value="Visible" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
        <TextBlock Text="FORCED"
                   Foreground="White"
                   FontSize="10"
                   FontWeight="SemiBold" />
      </Border>
    </DockPanel>
  </Border>
</UserControl>
