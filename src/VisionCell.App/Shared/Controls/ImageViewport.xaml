<UserControl x:Class="VisionCell.App.Shared.Controls.ImageViewport"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:VisionCell.App.Shared.Controls"
             x:Name="Root">
  <Border Style="{DynamicResource Card.Panel}">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <TextBlock Text="{Binding Title, ElementName=Root}"
                 Style="{DynamicResource Text.CardTitle}" />
      <TextBlock Grid.Row="1"
                 Text="{Binding StatusText, ElementName=Root}"
                 Style="{DynamicResource Text.Status}"
                 TextWrapping="Wrap"
                 Margin="0,6,0,10" />
      <Border Grid.Row="2"
              BorderBrush="{DynamicResource Brush.CardBorder}"
              BorderThickness="1"
              Background="{DynamicResource Brush.PanelAlt}"
              MinHeight="{Binding ViewportMinHeight, ElementName=Root}">
        <Grid>
          <Image Source="{Binding ImageSource, ElementName=Root}"
                 Stretch="Uniform"
                 RenderOptions.BitmapScalingMode="NearestNeighbor" />
          <controls:RoiOverlayCanvas OverlayItems="{Binding OverlayItems, ElementName=Root}"
                                     ImagePixelWidth="{Binding ImagePixelWidth, ElementName=Root}"
                                     ImagePixelHeight="{Binding ImagePixelHeight, ElementName=Root}"
                                     ShowLabels="{Binding ShowOverlayLabels, ElementName=Root}"
                                     IsHitTestVisible="False" />
          <TextBlock Text="No image"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center">
            <TextBlock.Style>
              <Style TargetType="TextBlock" BasedOn="{StaticResource Text.Status}">
                <Setter Property="Visibility" Value="Collapsed" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding ImageSource, ElementName=Root}" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Visible" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
        </Grid>
      </Border>
    </Grid>
  </Border>
</UserControl>
