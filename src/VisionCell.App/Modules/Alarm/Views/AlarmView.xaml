<UserControl x:Class="VisionCell.App.Modules.Alarm.Views.AlarmView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:VisionCell.App.Shared.Controls">
  <ScrollViewer VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled">
    <Grid MinWidth="0">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <controls:CommandBar Title="Alarm / Fault / Recovery"
                           StatusText="{Binding StatusText}"
                           AlertMessage="{Binding AlertMessage}"
                           HasAlert="{Binding HasAlert}">
        <controls:CommandBar.CommandContent>
          <Button Content="Refresh Alarms"
                  Command="{Binding RefreshCommand}"
                  ToolTip="Reload recent alarm and recovery records from SQLite."
                  Style="{DynamicResource Button.HmiCommand}"
                  MinWidth="132" />
        </controls:CommandBar.CommandContent>
      </controls:CommandBar>

      <UniformGrid Grid.Row="1" Columns="4" Margin="-8,12,-8,4">
        <controls:KpiCard Title="Visible Records"
                          Value="{Binding Alarms.Count}"
                          Detail="{Binding TotalAlarmDetail}" />
        <controls:KpiCard Title="Active"
                          Value="{Binding ActiveCount}"
                          Detail="{Binding AcknowledgedCount, StringFormat={}{0} acknowledged}" />
        <controls:KpiCard Title="Critical"
                          Value="{Binding CriticalCount}"
                          Detail="Critical severity count" />
        <controls:KpiCard Title="Last Refresh"
                          Value="{Binding LastRefreshText}"
                          Detail="{Binding StatusText}" />
      </UniformGrid>

      <Border Grid.Row="2" Style="{DynamicResource Card.Panel}" Margin="0,8,0,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Alarm Records" Style="{DynamicResource Text.CardTitle}" />
            <TextBlock Grid.Column="1"
                       Text="{Binding AcknowledgedCount, StringFormat={}{0} acknowledged}"
                       Style="{DynamicResource Text.Status}"
                       HorizontalAlignment="Right"
                       Margin="16,0,0,0" />
          </Grid>
          <Grid Grid.Row="1" Margin="0,10,0,8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="180" />
              <ColumnDefinition Width="180" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <CheckBox Content="Active only"
                      IsChecked="{Binding ShowActiveOnly}"
                      VerticalAlignment="Center"
                      Margin="0,0,16,0" />
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding SeverityFilterOptions}"
                      SelectedItem="{Binding SelectedSeverityFilter}"
                      Margin="0,0,12,0" />
            <ComboBox Grid.Column="2"
                      ItemsSource="{Binding AreaFilterOptions}"
                      SelectedItem="{Binding SelectedAreaFilter}"
                      Margin="0,0,12,0" />
            <TextBlock Grid.Column="3"
                       Text="{Binding FilterSummaryText}"
                       Style="{DynamicResource Text.Status}"
                       TextWrapping="Wrap"
                       VerticalAlignment="Center" />
          </Grid>
          <controls:EmptyState Grid.Row="2"
                               HasItems="{Binding HasAlarms}"
                               Title="No Alarm Records"
                               Detail="{Binding StatusText}"
                               Margin="0,0,0,8" />
          <ListView Grid.Row="3"
                    ItemsSource="{Binding Alarms}"
                    SelectedItem="{Binding SelectedAlarm}"
                    MinHeight="300"
                    Style="{DynamicResource ListView.HmiGrid}">
            <ListView.View>
              <GridView>
                <GridViewColumn Header="State" DisplayMemberBinding="{Binding StateText}" Width="118" />
                <GridViewColumn Header="Time" DisplayMemberBinding="{Binding OccurredAtText}" Width="150" />
                <GridViewColumn Header="Code" DisplayMemberBinding="{Binding Code}" Width="90" />
                <GridViewColumn Header="Severity" DisplayMemberBinding="{Binding Severity}" Width="94" />
                <GridViewColumn Header="Area" DisplayMemberBinding="{Binding Area}" Width="110" />
                <GridViewColumn Header="Message" DisplayMemberBinding="{Binding Message}" Width="420" />
                <GridViewColumn Header="Correlation" DisplayMemberBinding="{Binding CorrelationId}" Width="260" />
                <GridViewColumn Header="Acknowledged" DisplayMemberBinding="{Binding AcknowledgedAtText}" Width="150" />
              </GridView>
            </ListView.View>
          </ListView>
        </Grid>
      </Border>

      <Border Grid.Row="3" Style="{DynamicResource Card.Panel}" Margin="0,8,0,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <DockPanel>
            <Button DockPanel.Dock="Right"
                    Content="Acknowledge"
                    Command="{Binding AcknowledgeCommand}"
                    ToolTip="{Binding AcknowledgeDisabledReason}"
                    Style="{DynamicResource Button.HmiCommand.Compact}"
                    MinWidth="112" />
            <TextBlock Text="Recovery Detail" Style="{DynamicResource Text.CardTitle}" />
          </DockPanel>
          <UniformGrid Grid.Row="1" Columns="4" Margin="0,8,0,0">
            <StackPanel Margin="0,0,16,8">
              <TextBlock Text="Alarm ID" Style="{DynamicResource Text.MetricLabel}" />
              <TextBlock Text="{Binding SelectedAlarm.Id, TargetNullValue=-}"
                         Style="{DynamicResource Text.StatusStrong}"
                         TextWrapping="Wrap" />
            </StackPanel>
            <StackPanel Margin="0,0,16,8">
              <TextBlock Text="Area" Style="{DynamicResource Text.MetricLabel}" />
              <TextBlock Text="{Binding SelectedAlarm.Area, TargetNullValue=-}"
                         Style="{DynamicResource Text.StatusStrong}" />
            </StackPanel>
            <StackPanel Margin="0,0,16,8">
              <TextBlock Text="Code" Style="{DynamicResource Text.MetricLabel}" />
              <TextBlock Text="{Binding SelectedAlarm.Code, TargetNullValue=-}"
                         Style="{DynamicResource Text.StatusStrong}" />
            </StackPanel>
            <StackPanel Margin="0,0,0,8">
              <TextBlock Text="State" Style="{DynamicResource Text.MetricLabel}" />
              <TextBlock Text="{Binding SelectedAlarm.StateText, TargetNullValue=-}"
                         Style="{DynamicResource Text.StatusStrong}" />
            </StackPanel>
          </UniformGrid>
          <StackPanel Grid.Row="2" Margin="0,4,0,8">
            <TextBlock Text="Recovery Hint" Style="{DynamicResource Text.MetricLabel}" />
            <TextBlock Text="{Binding SelectedAlarm.RecoveryHint, TargetNullValue=-}"
                       Style="{DynamicResource Text.Status}"
                       TextWrapping="Wrap" />
          </StackPanel>
          <StackPanel Grid.Row="3" Margin="0,4,0,8">
            <TextBlock Text="Recovery Boundary"
                       Style="{DynamicResource Text.SectionHeader}"
                       Margin="0,0,0,4" />
            <ListView ItemsSource="{Binding RecoveryBoundaryItems}"
                      MinHeight="120"
                      Style="{DynamicResource ListView.HmiGrid}">
              <ListView.View>
                <GridView>
                  <GridViewColumn Header="Boundary" Width="190">
                    <GridViewColumn.CellTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding Boundary}"
                                   TextWrapping="Wrap"
                                   Style="{DynamicResource Text.StatusStrong}" />
                      </DataTemplate>
                    </GridViewColumn.CellTemplate>
                  </GridViewColumn>
                  <GridViewColumn Header="State"
                                  DisplayMemberBinding="{Binding State}"
                                  Width="130" />
                  <GridViewColumn Header="Operator Note" Width="500">
                    <GridViewColumn.CellTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding Detail}"
                                   TextWrapping="Wrap"
                                   Style="{DynamicResource Text.Status}" />
                      </DataTemplate>
                    </GridViewColumn.CellTemplate>
                  </GridViewColumn>
                </GridView>
              </ListView.View>
            </ListView>
          </StackPanel>
          <Grid Grid.Row="4" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="280" />
            </Grid.ColumnDefinitions>
            <StackPanel>
              <TextBlock Text="Action Memo" Style="{DynamicResource Text.MetricLabel}" />
              <TextBox Text="{Binding ActionMemoText, UpdateSourceTrigger=PropertyChanged}"
                       IsEnabled="{Binding IsActionMemoEditable}"
                       ToolTip="{Binding AcknowledgeDisabledReason}"
                       MinHeight="72"
                       TextWrapping="Wrap"
                       AcceptsReturn="True" />
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="16,0,0,0">
              <TextBlock Text="Previous Memo" Style="{DynamicResource Text.MetricLabel}" />
              <TextBlock Text="{Binding SelectedAlarm.ActionMemo, TargetNullValue=-}"
                         Style="{DynamicResource Text.Status}"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Grid>
        </Grid>
      </Border>
    </Grid>
  </ScrollViewer>
</UserControl>
