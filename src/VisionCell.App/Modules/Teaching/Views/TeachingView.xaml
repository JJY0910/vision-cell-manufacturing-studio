<UserControl x:Class="VisionCell.App.Modules.Teaching.Views.TeachingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <DockPanel>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
          <Button Content="Refresh"
                  Command="{Binding RefreshCommand}"
                  ToolTip="Reload saved teaching points and active recipe context."
                  Height="36"
                  MinWidth="96"
                  Margin="0,0,8,0" />
          <Button Content="Go To"
                  Command="{Binding GoToSelectedCommand}"
                  ToolTip="Move to the selected teaching point through the Application motion boundary."
                  Height="36"
                  MinWidth="88" />
        </StackPanel>
        <StackPanel>
          <TextBlock Text="Teaching" Style="{DynamicResource Text.PageTitle}" />
          <TextBlock Text="{Binding StatusText}"
                     Style="{DynamicResource Text.Status}"
                     Margin="0,4,0,0" />
        </StackPanel>
      </DockPanel>

      <Border Grid.Row="1" Style="{DynamicResource Card.Panel}" Margin="0,12,0,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <TextBlock Text="Save Current Position" Style="{DynamicResource Text.CardTitle}" />
          <WrapPanel Grid.Row="1" Margin="0,12,0,0">
            <StackPanel Width="180" Style="{DynamicResource Form.Field}">
              <TextBlock Text="Name" Style="{DynamicResource Text.MetricLabel}" />
              <TextBox Text="{Binding NameText, UpdateSourceTrigger=PropertyChanged}"
                       Style="{DynamicResource TextBox.HmiInput}" />
            </StackPanel>
            <StackPanel Width="150" Style="{DynamicResource Form.Field}">
              <TextBlock Text="Role" Style="{DynamicResource Text.MetricLabel}" />
              <ComboBox ItemsSource="{Binding RoleOptions}"
                        SelectedItem="{Binding SelectedRole}"
                        Style="{DynamicResource ComboBox.HmiInput}" />
            </StackPanel>
            <StackPanel Width="170" Style="{DynamicResource Form.Field}">
              <TextBlock Text="Active Recipe" Style="{DynamicResource Text.MetricLabel}" />
              <TextBox Text="{Binding ActiveRecipeIdText, UpdateSourceTrigger=PropertyChanged}"
                       Style="{DynamicResource TextBox.HmiInput}" />
            </StackPanel>
            <StackPanel Width="260" Style="{DynamicResource Form.Field}">
              <TextBlock Text="Memo" Style="{DynamicResource Text.MetricLabel}" />
              <TextBox Text="{Binding MemoText, UpdateSourceTrigger=PropertyChanged}"
                       Style="{DynamicResource TextBox.HmiInput}" />
            </StackPanel>
          </WrapPanel>
          <WrapPanel Grid.Row="2" Margin="0,4,0,0">
            <StackPanel Width="88" Style="{DynamicResource Form.Field}">
              <TextBlock Text="Tol X" Style="{DynamicResource Text.MetricLabel}" />
              <TextBox Text="{Binding ToleranceXText, UpdateSourceTrigger=PropertyChanged}"
                       Style="{DynamicResource TextBox.HmiInput}" />
            </StackPanel>
            <StackPanel Width="88" Style="{DynamicResource Form.Field}">
              <TextBlock Text="Tol Y" Style="{DynamicResource Text.MetricLabel}" />
              <TextBox Text="{Binding ToleranceYText, UpdateSourceTrigger=PropertyChanged}"
                       Style="{DynamicResource TextBox.HmiInput}" />
            </StackPanel>
            <StackPanel Width="88" Style="{DynamicResource Form.Field}">
              <TextBlock Text="Tol Z" Style="{DynamicResource Text.MetricLabel}" />
              <TextBox Text="{Binding ToleranceZText, UpdateSourceTrigger=PropertyChanged}"
                       Style="{DynamicResource TextBox.HmiInput}" />
            </StackPanel>
            <StackPanel Width="88" Style="{DynamicResource Form.Field}">
              <TextBlock Text="Tol T" Style="{DynamicResource Text.MetricLabel}" />
              <TextBox Text="{Binding ToleranceThetaText, UpdateSourceTrigger=PropertyChanged}"
                       Style="{DynamicResource TextBox.HmiInput}" />
            </StackPanel>
            <Button Content="Save Current"
                    Command="{Binding SaveCurrentPositionCommand}"
                    ToolTip="Save the current controller position as a teaching point."
                    Style="{DynamicResource Button.HmiCommand.Compact}"
                    MinWidth="128" />
            <Button Content="Update Selected"
                    Command="{Binding UpdateSelectedCommand}"
                    ToolTip="Update the selected teaching point and write a history row."
                    Style="{DynamicResource Button.HmiCommand.Compact}"
                    MinWidth="132" />
            <Button Content="Delete Selected"
                    Command="{Binding DeleteSelectedCommand}"
                    ToolTip="Delete the selected teaching point after operator confirmation."
                    Style="{DynamicResource Button.HmiCommand.Compact}"
                    MinWidth="128" />
          </WrapPanel>
          <TextBlock Grid.Row="3"
                     Text="{Binding ActiveRecipeContextText, StringFormat=Recipe Context: {0}}"
                     Style="{DynamicResource Text.Status}"
                     TextWrapping="Wrap" />
        </Grid>
      </Border>

      <Border Grid.Row="2" Style="{DynamicResource Card.Panel}" Margin="0,8,0,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <DockPanel>
            <TextBlock Text="Teaching Points" Style="{DynamicResource Text.CardTitle}" />
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
              <TextBlock Text="{Binding Points.Count, StringFormat={}{0} points}"
                         Style="{DynamicResource Text.Status}"
                         VerticalAlignment="Center"
                         Margin="0,0,12,0" />
              <Button Content="Refresh History"
                      Command="{Binding RefreshSelectedPointHistoryCommand}"
                      ToolTip="Reload history for the selected teaching point."
                      Height="32"
                      MinWidth="126" />
            </StackPanel>
          </DockPanel>
          <ListView Grid.Row="1"
                    ItemsSource="{Binding Points}"
                    SelectedItem="{Binding SelectedPoint}"
                    Style="{DynamicResource ListView.HmiGrid}">
            <ListView.View>
              <GridView>
                <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="150" />
                <GridViewColumn Header="Role" DisplayMemberBinding="{Binding Role}" Width="100" />
                <GridViewColumn Header="Position" DisplayMemberBinding="{Binding PositionText}" Width="260" />
                <GridViewColumn Header="Tolerance" DisplayMemberBinding="{Binding ToleranceText}" Width="260" />
                <GridViewColumn Header="Updated" DisplayMemberBinding="{Binding UpdatedAtText}" Width="150" />
                <GridViewColumn Header="Memo" DisplayMemberBinding="{Binding Memo}" Width="220" />
              </GridView>
            </ListView.View>
          </ListView>
        </Grid>
      </Border>

      <Border Grid.Row="3" Style="{DynamicResource Card.Panel}" Margin="0,8,0,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <DockPanel>
            <TextBlock Text="Selected Point History" Style="{DynamicResource Text.CardTitle}" />
            <TextBlock DockPanel.Dock="Right"
                       Text="{Binding HistoryStatus}"
                       Style="{DynamicResource Text.Status}" />
          </DockPanel>
          <ListView Grid.Row="1"
                    ItemsSource="{Binding SelectedPointHistory}"
                    Style="{DynamicResource ListView.HmiGrid}">
            <ListView.View>
              <GridView>
                <GridViewColumn Header="Time" DisplayMemberBinding="{Binding CreatedAtText}" Width="150" />
                <GridViewColumn Header="Action" DisplayMemberBinding="{Binding ActionText}" Width="90" />
                <GridViewColumn Header="Recipe" DisplayMemberBinding="{Binding RecipeText}" Width="110" />
                <GridViewColumn Header="Before" DisplayMemberBinding="{Binding BeforeText}" Width="360" />
                <GridViewColumn Header="After" DisplayMemberBinding="{Binding AfterText}" Width="360" />
              </GridView>
            </ListView.View>
          </ListView>
        </Grid>
      </Border>
    </Grid>
  </ScrollViewer>
</UserControl>
