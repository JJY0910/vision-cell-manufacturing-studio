<UserControl x:Class="VisionCell.App.Modules.Settings.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:VisionCell.App.Shared.Controls">
  <ScrollViewer VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled">
    <Grid MinWidth="0">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <controls:CommandBar Title="Settings"
                           StatusText="Runtime settings are currently read-only; simulator and virtual camera boundaries remain explicit." />

      <Border Grid.Row="1" Style="{DynamicResource Card.Panel}" Margin="0,12,0,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <TextBlock Text="Runtime Scope" Style="{DynamicResource Text.CardTitle}" />
          <UniformGrid Grid.Row="1" Columns="3" Margin="0,4,0,0">
            <StackPanel Margin="0,0,16,8">
              <TextBlock Text="Equipment Mode" Style="{DynamicResource Text.MetricLabel}" />
              <TextBlock Text="Simulator only" Style="{DynamicResource Text.StatusStrong}" />
            </StackPanel>
            <StackPanel Margin="0,0,16,8">
              <TextBlock Text="Camera Mode" Style="{DynamicResource Text.MetricLabel}" />
              <TextBlock Text="Virtual camera only" Style="{DynamicResource Text.StatusStrong}" />
            </StackPanel>
            <StackPanel Margin="0,0,0,8">
              <TextBlock Text="Hardware Validation" Style="{DynamicResource Text.MetricLabel}" />
              <TextBlock Text="Not connected to real equipment" Style="{DynamicResource Text.StatusStrong}" TextWrapping="Wrap" />
            </StackPanel>
          </UniformGrid>
        </Grid>
      </Border>
    </Grid>
  </ScrollViewer>
</UserControl>
