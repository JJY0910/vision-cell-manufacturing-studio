<UserControl x:Class="VisionCell.App.Modules.Inspection.Views.InspectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <DockPanel>
      <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
        <Button Content="Refresh Recipe"
                Command="{Binding RefreshActiveRecipeCommand}"
                Height="36"
                MinWidth="124"
                Margin="0,0,8,0" />
        <Button Content="Run Inspection"
                Command="{Binding RunInspectionCommand}"
                Height="36"
                MinWidth="132"
                Margin="0,0,8,0" />
        <Button Content="Stop"
                Command="{Binding StopInspectionCommand}"
                Height="36"
                MinWidth="76" />
      </StackPanel>
      <StackPanel>
        <TextBlock Text="Inspection" Style="{DynamicResource Text.PageTitle}" />
        <TextBlock Text="{Binding StatusText}"
                   Style="{DynamicResource Text.Status}"
                   Margin="0,4,0,0" />
      </StackPanel>
    </DockPanel>

    <UniformGrid Grid.Row="1" Columns="4" Margin="-8,12,-8,0">
      <Border Style="{DynamicResource Card.Panel}">
        <StackPanel>
          <TextBlock Text="Active Recipe" Style="{DynamicResource Text.CardTitle}" />
          <TextBlock Text="{Binding ActiveRecipeText}"
                     Style="{DynamicResource Text.MetricValue}"
                     TextWrapping="Wrap" />
        </StackPanel>
      </Border>
      <Border Style="{DynamicResource Card.Panel}">
        <StackPanel>
          <TextBlock Text="Precheck" Style="{DynamicResource Text.CardTitle}" />
          <TextBlock Text="{Binding PrecheckStatusText}"
                     Style="{DynamicResource Text.StatusStrong}"
                     TextWrapping="Wrap" />
        </StackPanel>
      </Border>
      <Border Style="{DynamicResource Card.Panel}">
        <StackPanel>
          <TextBlock Text="Last Check" Style="{DynamicResource Text.CardTitle}" />
          <TextBlock Text="{Binding LastCheckText}"
                     Style="{DynamicResource Text.MetricValue}"
                     TextWrapping="Wrap" />
        </StackPanel>
      </Border>
      <Border Style="{DynamicResource Card.Panel}">
        <StackPanel>
          <TextBlock Text="Correlation" Style="{DynamicResource Text.CardTitle}" />
          <TextBlock Text="{Binding LastRunCorrelationId}"
                     Style="{DynamicResource Text.MetricValue}"
                     TextWrapping="Wrap" />
        </StackPanel>
      </Border>
    </UniformGrid>

    <Grid Grid.Row="2" Margin="0,16,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="2*" />
        <ColumnDefinition Width="3*" />
      </Grid.ColumnDefinitions>

      <Border Style="{DynamicResource Card.Panel}" Margin="0,0,12,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <TextBlock Text="Last Grab" Style="{DynamicResource Text.CardTitle}" />
          <TextBlock Grid.Row="1"
                     Text="{Binding LastGrabText}"
                     Style="{DynamicResource Text.Status}"
                     TextWrapping="Wrap"
                     Margin="0,6,0,10" />
          <Border Grid.Row="2"
                  BorderBrush="{DynamicResource Brush.CardBorder}"
                  BorderThickness="1"
                  Background="{DynamicResource Brush.PanelAlt}"
                  MinHeight="260">
            <Image Source="{Binding LastGrabImageSource}"
                   Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="NearestNeighbor" />
          </Border>
        </Grid>
      </Border>

      <ItemsControl Grid.Column="1"
                    ItemsSource="{Binding SequenceSteps}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Style="{DynamicResource Card.Panel}">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="180" />
                  <ColumnDefinition Width="110" />
                  <ColumnDefinition Width="90" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Name}" Style="{DynamicResource Text.CardTitle}" />
                <TextBlock Grid.Column="1"
                           Text="{Binding Status}"
                           Style="{DynamicResource Text.StatusStrong}" />
                <TextBlock Grid.Column="2"
                           Text="{Binding ElapsedText}"
                           Style="{DynamicResource Text.Status}" />
                <TextBlock Grid.Column="3"
                           Text="{Binding Detail}"
                           Style="{DynamicResource Text.Status}"
                           TextWrapping="Wrap" />
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </Grid>
  </Grid>
</UserControl>
