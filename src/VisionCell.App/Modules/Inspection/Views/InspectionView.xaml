<UserControl x:Class="VisionCell.App.Modules.Inspection.Views.InspectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:VisionCell.App.Shared.Controls">
  <ScrollViewer VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled">
    <Grid MinWidth="0">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <controls:CommandBar Title="Inspection"
                         StatusText="{Binding StatusText}"
                         AlertMessage="{Binding AlertMessage}"
                         HasAlert="{Binding HasAlert}">
      <controls:CommandBar.CommandContent>
        <WrapPanel>
          <Button Content="Refresh Recipe"
                  Command="{Binding RefreshActiveRecipeCommand}"
                  ToolTip="Refresh the active recipe precheck before starting inspection."
                  Style="{DynamicResource Button.HmiCommand}"
                  MinWidth="124" />
          <Button Content="Run Inspection"
                  Command="{Binding RunInspectionCommand}"
                  ToolTip="Run the simulator-backed inspection sequence through the Application use case."
                  Style="{DynamicResource Button.HmiCommand}"
                  MinWidth="132" />
          <Button Content="Stop"
                  Command="{Binding StopInspectionCommand}"
                  ToolTip="Request cancellation for the active inspection run."
                  Style="{DynamicResource Button.HmiCommand}" />
        </WrapPanel>
      </controls:CommandBar.CommandContent>
    </controls:CommandBar>

    <UniformGrid Grid.Row="1" Columns="4" Margin="-8,12,-8,0">
      <controls:KpiCard Title="Active Recipe"
                        Value="{Binding ActiveRecipeText}"
                        Detail="Context" />
      <controls:KpiCard Title="Precheck"
                        Value="{Binding PrecheckStatusText}"
                        Detail="{Binding StatusText}" />
      <controls:KpiCard Title="Last Check"
                        Value="{Binding LastCheckText}"
                        Detail="Updated" />
      <controls:KpiCard Title="Correlation"
                        Value="{Binding LastRunCorrelationId}"
                        Detail="Run ID" />
    </UniformGrid>

    <Grid Grid.Row="2" Margin="0,16,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="2*" MinWidth="0" />
        <ColumnDefinition Width="3*" MinWidth="0" />
      </Grid.ColumnDefinitions>

      <controls:ImageViewport Title="Last Grab"
                              StatusText="{Binding LastGrabText}"
                              ImageSource="{Binding LastGrabImageSource}"
                              OverlayItems="{Binding LastGrabOverlayItems}"
                              ImagePixelWidth="{Binding LastGrabImagePixelWidth}"
                              ImagePixelHeight="{Binding LastGrabImagePixelHeight}"
                              ViewportMinHeight="260"
                              Margin="0,0,12,0" />

      <controls:SequenceTimeline Grid.Column="1"
                                 DataContext="{Binding SequenceSteps}" />
    </Grid>
    </Grid>
  </ScrollViewer>
</UserControl>
