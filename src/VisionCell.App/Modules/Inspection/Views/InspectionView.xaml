<UserControl x:Class="VisionCell.App.Modules.Inspection.Views.InspectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:VisionCell.App.Shared.Controls">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <DockPanel>
      <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
        <Button Content="Refresh Recipe"
                Command="{Binding RefreshActiveRecipeCommand}"
                ToolTip="Refresh the active recipe precheck before starting inspection."
                Height="36"
                MinWidth="124"
                Margin="0,0,8,0" />
        <Button Content="Run Inspection"
                Command="{Binding RunInspectionCommand}"
                ToolTip="Run the simulator-backed inspection sequence through the Application use case."
                Height="36"
                MinWidth="132"
                Margin="0,0,8,0" />
        <Button Content="Stop"
                Command="{Binding StopInspectionCommand}"
                ToolTip="Request cancellation for the active inspection run."
                Height="36"
                MinWidth="76" />
      </StackPanel>
      <StackPanel>
        <TextBlock Text="Inspection" Style="{DynamicResource Text.PageTitle}" />
        <TextBlock Text="{Binding StatusText}"
                   Style="{DynamicResource Text.Status}"
                   Margin="0,4,0,0" />
        <controls:ErrorBanner Message="{Binding AlertMessage}"
                              IsOpen="{Binding HasAlert}"
                              Margin="0,8,0,0" />
      </StackPanel>
    </DockPanel>

    <UniformGrid Grid.Row="1" Columns="4" Margin="-8,12,-8,0">
      <Border Style="{DynamicResource Card.Panel}">
        <StackPanel>
          <TextBlock Text="Active Recipe" Style="{DynamicResource Text.CardTitle}" />
          <TextBlock Text="{Binding ActiveRecipeText}"
                     Style="{DynamicResource Text.MetricValue}"
                     TextWrapping="Wrap" />
        </StackPanel>
      </Border>
      <Border Style="{DynamicResource Card.Panel}">
        <StackPanel>
          <TextBlock Text="Precheck" Style="{DynamicResource Text.CardTitle}" />
          <TextBlock Text="{Binding PrecheckStatusText}"
                     Style="{DynamicResource Text.StatusStrong}"
                     TextWrapping="Wrap" />
        </StackPanel>
      </Border>
      <Border Style="{DynamicResource Card.Panel}">
        <StackPanel>
          <TextBlock Text="Last Check" Style="{DynamicResource Text.CardTitle}" />
          <TextBlock Text="{Binding LastCheckText}"
                     Style="{DynamicResource Text.MetricValue}"
                     TextWrapping="Wrap" />
        </StackPanel>
      </Border>
      <Border Style="{DynamicResource Card.Panel}">
        <StackPanel>
          <TextBlock Text="Correlation" Style="{DynamicResource Text.CardTitle}" />
          <TextBlock Text="{Binding LastRunCorrelationId}"
                     Style="{DynamicResource Text.MetricValue}"
                     TextWrapping="Wrap" />
        </StackPanel>
      </Border>
    </UniformGrid>

    <Grid Grid.Row="2" Margin="0,16,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="2*" />
        <ColumnDefinition Width="3*" />
      </Grid.ColumnDefinitions>

      <controls:ImageViewport Title="Last Grab"
                              StatusText="{Binding LastGrabText}"
                              ImageSource="{Binding LastGrabImageSource}"
                              ViewportMinHeight="260"
                              Margin="0,0,12,0" />

      <controls:SequenceTimeline Grid.Column="1"
                                 DataContext="{Binding SequenceSteps}" />
    </Grid>
    </Grid>
  </ScrollViewer>
</UserControl>
