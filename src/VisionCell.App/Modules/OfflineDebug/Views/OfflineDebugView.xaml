<UserControl x:Class="VisionCell.App.Modules.OfflineDebug.Views.OfflineDebugView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:VisionCell.App.Shared.Controls">
  <ScrollViewer VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled">
    <Grid MinWidth="0">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <controls:CommandBar Title="Offline Debug"
                           StatusText="{Binding StatusText}"
                           AlertMessage="{Binding AlertMessage}"
                           HasAlert="{Binding HasAlert}">
        <controls:CommandBar.CommandContent>
          <WrapPanel>
            <Button Content="Refresh Results"
                    Command="{Binding RefreshResultsCommand}"
                    ToolTip="Reload recent persisted inspection result records."
                    Style="{DynamicResource Button.HmiCommand}"
                    MinWidth="132" />
            <Button Content="Load Artifacts"
                    Command="{Binding LoadSelectedArtifactsCommand}"
                    ToolTip="Select an inspection result before loading overlay and height-map previews."
                    Style="{DynamicResource Button.HmiCommand}"
                    MinWidth="132" />
            <Button Content="Open Overlay"
                    Command="{Binding OpenOverlayArtifactCommand}"
                    ToolTip="Select an inspection result before opening the overlay artifact."
                    Style="{DynamicResource Button.HmiCommand}"
                    MinWidth="124" />
            <Button Content="Open Height Map"
                    Command="{Binding OpenHeightMapArtifactCommand}"
                    ToolTip="Select an inspection result before opening the height-map artifact."
                    Style="{DynamicResource Button.HmiCommand}"
                    MinWidth="148" />
            <Button Content="Prepare Re-inspect"
                    Command="{Binding PrepareReinspectCommand}"
                    ToolTip="Select an inspection result before preparing a simulator re-inspection context."
                    Style="{DynamicResource Button.HmiCommand}"
                    MinWidth="148" />
            <Button Content="Run Re-inspect"
                    Command="{Binding RunReinspectCommand}"
                    ToolTip="{Binding ReinspectRunDisabledReason}"
                    Style="{DynamicResource Button.HmiCommand}"
                    MinWidth="136" />
          </WrapPanel>
        </controls:CommandBar.CommandContent>
      </controls:CommandBar>

      <UniformGrid Grid.Row="1" Columns="4" Margin="-8,12,-8,4">
        <Border Style="{DynamicResource Card.Panel}">
          <StackPanel>
            <TextBlock Text="Results" Style="{DynamicResource Text.CardTitle}" />
            <TextBlock Text="{Binding Results.Count}" Style="{DynamicResource Text.MetricValue}" />
          </StackPanel>
        </Border>
        <Border Style="{DynamicResource Card.Panel}">
          <StackPanel>
            <TextBlock Text="Pass" Style="{DynamicResource Text.CardTitle}" />
            <TextBlock Text="{Binding PassCount}" Style="{DynamicResource Text.MetricValue}" />
          </StackPanel>
        </Border>
        <Border Style="{DynamicResource Card.Panel}">
          <StackPanel>
            <TextBlock Text="Fail" Style="{DynamicResource Text.CardTitle}" />
            <TextBlock Text="{Binding FailCount}" Style="{DynamicResource Text.MetricValue}" />
            <TextBlock Text="{Binding DefectCount, StringFormat={}{0} defects}"
                       Style="{DynamicResource Text.Status}" />
          </StackPanel>
        </Border>
        <Border Style="{DynamicResource Card.Panel}">
          <StackPanel>
            <TextBlock Text="Last Refresh" Style="{DynamicResource Text.CardTitle}" />
            <TextBlock Text="{Binding LastRefreshText}"
                       Style="{DynamicResource Text.MetricValue}"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>
      </UniformGrid>

      <Border Grid.Row="2" Style="{DynamicResource Card.Panel}" Margin="0,8,0,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Result List" Style="{DynamicResource Text.CardTitle}" />
            <TextBlock Grid.Column="1"
                       Text="{Binding StatusText}"
                       Style="{DynamicResource Text.Status}"
                       HorizontalAlignment="Right"
                       TextWrapping="Wrap"
                       Margin="16,0,0,0" />
          </Grid>
          <controls:EmptyState Grid.Row="1"
                               HasItems="{Binding HasResults}"
                               Title="No Inspection Results"
                               Detail="{Binding StatusText}"
                               Margin="0,0,0,8" />
          <ListView Grid.Row="2"
                    ItemsSource="{Binding Results}"
                    SelectedItem="{Binding SelectedResult}"
                    MinHeight="220"
                    Style="{DynamicResource ListView.HmiGrid}">
            <ListView.View>
              <GridView>
                <GridViewColumn Header="Created" DisplayMemberBinding="{Binding CreatedAtText}" Width="150" />
                <GridViewColumn Header="Lot" DisplayMemberBinding="{Binding LotId}" Width="160" />
                <GridViewColumn Header="Recipe" DisplayMemberBinding="{Binding RecipeId}" Width="170" />
                <GridViewColumn Header="Version" DisplayMemberBinding="{Binding RecipeVersion}" Width="90" />
                <GridViewColumn Header="Judge" DisplayMemberBinding="{Binding JudgmentText}" Width="90" />
                <GridViewColumn Header="Defects" DisplayMemberBinding="{Binding DefectCount}" Width="80" />
                <GridViewColumn Header="Cycle" DisplayMemberBinding="{Binding CycleTimeText}" Width="90" />
                <GridViewColumn Header="Overlay" Width="280">
                  <GridViewColumn.CellTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding OverlayImagePath}"
                                 TextWrapping="Wrap"
                                 Style="{DynamicResource Text.Status}" />
                    </DataTemplate>
                  </GridViewColumn.CellTemplate>
                </GridViewColumn>
                <GridViewColumn Header="Artifacts" Width="360">
                  <GridViewColumn.CellTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding ArtifactStatusSummary}"
                                 TextWrapping="Wrap"
                                 Style="{DynamicResource Text.Status}" />
                    </DataTemplate>
                  </GridViewColumn.CellTemplate>
                </GridViewColumn>
              </GridView>
            </ListView.View>
          </ListView>
        </Grid>
      </Border>

      <Border Grid.Row="3" Style="{DynamicResource Card.Panel}" Margin="0,8,0,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <TextBlock Text="Selected Result Detail" Style="{DynamicResource Text.CardTitle}" />

          <UniformGrid Grid.Row="1" Columns="4" Margin="0,8,0,0">
            <StackPanel Margin="0,0,16,8">
              <TextBlock Text="Result ID" Style="{DynamicResource Text.MetricLabel}" />
              <TextBlock Text="{Binding SelectedResult.Id, TargetNullValue=-}"
                         Style="{DynamicResource Text.StatusStrong}"
                         TextWrapping="Wrap" />
            </StackPanel>
            <StackPanel Margin="0,0,16,8">
              <TextBlock Text="Correlation" Style="{DynamicResource Text.MetricLabel}" />
              <TextBlock Text="{Binding SelectedResult.CorrelationId, TargetNullValue=-}"
                         Style="{DynamicResource Text.StatusStrong}"
                         TextWrapping="Wrap" />
            </StackPanel>
            <StackPanel Margin="0,0,16,8">
              <TextBlock Text="Judge" Style="{DynamicResource Text.MetricLabel}" />
              <TextBlock Text="{Binding SelectedResult.JudgmentText, TargetNullValue=-}"
                         Style="{DynamicResource Text.StatusStrong}" />
            </StackPanel>
            <StackPanel Margin="0,0,0,8">
              <TextBlock Text="Cycle" Style="{DynamicResource Text.MetricLabel}" />
              <TextBlock Text="{Binding SelectedResult.CycleTimeText, TargetNullValue=-}"
                         Style="{DynamicResource Text.StatusStrong}" />
            </StackPanel>
          </UniformGrid>

          <Grid Grid.Row="2" Margin="0,4,0,0">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Text="{Binding SelectedResult.SourceImagePath, StringFormat=Source: {0}, TargetNullValue=Source: -}"
                       Style="{DynamicResource Text.Status}"
                       TextWrapping="Wrap" />
            <TextBlock Grid.Row="1"
                       Text="{Binding SelectedResult.OverlayImagePath, StringFormat=Overlay: {0}, TargetNullValue=Overlay: -}"
                       Style="{DynamicResource Text.Status}"
                       TextWrapping="Wrap"
                       Margin="0,4,0,0" />
            <TextBlock Grid.Row="2"
                       Text="{Binding SelectedResult.HeightMapPath, StringFormat=Height Map: {0}, TargetNullValue=Height Map: -}"
                       Style="{DynamicResource Text.Status}"
                       TextWrapping="Wrap"
                       Margin="0,4,0,0" />
            <TextBlock Grid.Row="3"
                       Text="{Binding SelectedResult.OverlayArtifactStatus, StringFormat=Overlay Status: {0}, TargetNullValue=Overlay Status: -}"
                       Style="{DynamicResource Text.Status}"
                       TextWrapping="Wrap"
                       Margin="0,4,0,0" />
            <TextBlock Grid.Row="4"
                       Text="{Binding SelectedResult.HeightMapArtifactStatus, StringFormat=Height Map Status: {0}, TargetNullValue=Height Map Status: -}"
                       Style="{DynamicResource Text.Status}"
                       TextWrapping="Wrap"
                       Margin="0,4,0,0" />
          </Grid>

          <Grid Grid.Row="3" Margin="0,8,0,0">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Text="{Binding ArtifactPreviewStatusText}"
                       Style="{DynamicResource Text.Status}"
                       TextWrapping="Wrap" />
            <TextBlock Grid.Row="1"
                       Text="{Binding ArtifactOpenStatusText}"
                       Style="{DynamicResource Text.Status}"
                       TextWrapping="Wrap"
                       Margin="0,4,0,0" />
            <UniformGrid Grid.Row="2" Columns="2" Margin="0,8,0,0">
              <controls:ImageViewport Title="Overlay Preview"
                                      StatusText="{Binding SelectedResult.OverlayArtifactStatus, TargetNullValue=Overlay: -}"
                                      ImageSource="{Binding OverlayPreviewImageSource}"
                                      OverlayItems="{Binding SelectedResult.OverlayItems}"
                                      ImagePixelWidth="{Binding OverlayImagePixelWidth}"
                                      ImagePixelHeight="{Binding OverlayImagePixelHeight}"
                                      ViewportMinHeight="160"
                                      Margin="0,0,8,0" />
              <controls:ImageViewport Title="Height Map Preview"
                                      StatusText="{Binding SelectedResult.HeightMapArtifactStatus, TargetNullValue=Height Map: -}"
                                      ImageSource="{Binding HeightMapPreviewImageSource}"
                                      ViewportMinHeight="160"
                                      Margin="8,0,0,0" />
            </UniformGrid>
            <TextBlock Grid.Row="3"
                       Text="{Binding ReinspectStatusText}"
                       Style="{DynamicResource Text.Status}"
                       TextWrapping="Wrap"
                       Margin="0,8,0,0" />
            <TextBlock Grid.Row="4"
                       Text="{Binding PreparedReinspectSummary}"
                       Style="{DynamicResource Text.StatusStrong}"
                       TextWrapping="Wrap"
                       Margin="0,4,0,0" />
            <TextBlock Grid.Row="5"
                       Text="{Binding PreparedReinspectArtifactSummary}"
                       Style="{DynamicResource Text.Status}"
                       TextWrapping="Wrap"
                       Margin="0,4,0,0" />
            <TextBlock Grid.Row="6"
                       Text="{Binding ReinspectSourceImageReadinessSummary}"
                       Style="{DynamicResource Text.StatusStrong}"
                       TextWrapping="Wrap"
                       Margin="0,4,0,0" />
            <TextBlock Grid.Row="7"
                       Text="{Binding ReinspectSourceImageReadinessDetail}"
                       Style="{DynamicResource Text.Status}"
                       TextWrapping="Wrap"
                       Margin="0,4,0,0" />
            <TextBlock Grid.Row="8"
                       Text="{Binding ReinspectRecipePolicySummary}"
                       Style="{DynamicResource Text.StatusStrong}"
                       TextWrapping="Wrap"
                       Margin="0,4,0,0" />
            <TextBlock Grid.Row="9"
                       Text="{Binding ReinspectRecipePolicyDetail}"
                       Style="{DynamicResource Text.Status}"
                       TextWrapping="Wrap"
                       Margin="0,4,0,0" />
            <TextBlock Grid.Row="10"
                       Text="{Binding ReinspectRunDisabledReason, StringFormat=Run Re-inspect: {0}}"
                       Style="{DynamicResource Text.Status}"
                       TextWrapping="Wrap"
                       Margin="0,4,0,0" />
            <TextBlock Grid.Row="11"
                       Text="Re-inspect Readiness"
                       Style="{DynamicResource Text.SectionHeader}"
                       Margin="0,8,0,4" />
            <ListView Grid.Row="12"
                      ItemsSource="{Binding ReinspectReadinessItems}"
                      MinHeight="120"
                      Style="{DynamicResource ListView.HmiGrid}">
              <ListView.View>
                <GridView>
                  <GridViewColumn Header="Boundary" Width="190">
                    <GridViewColumn.CellTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding Step}"
                                   TextWrapping="Wrap"
                                   Style="{DynamicResource Text.StatusStrong}" />
                      </DataTemplate>
                    </GridViewColumn.CellTemplate>
                  </GridViewColumn>
                  <GridViewColumn Header="State"
                                  DisplayMemberBinding="{Binding State}"
                                  Width="130" />
                  <GridViewColumn Header="Operator Note" Width="500">
                    <GridViewColumn.CellTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding Detail}"
                                   TextWrapping="Wrap"
                                   Style="{DynamicResource Text.Status}" />
                      </DataTemplate>
                    </GridViewColumn.CellTemplate>
                  </GridViewColumn>
                </GridView>
              </ListView.View>
            </ListView>
            <TextBlock Grid.Row="13"
                       Text="{Binding ReinspectComparisonSummary}"
                       Style="{DynamicResource Text.StatusStrong}"
                       TextWrapping="Wrap"
                       Margin="0,4,0,0" />
            <TextBlock Grid.Row="14"
                       Text="{Binding ReinspectComparisonDetail}"
                       Style="{DynamicResource Text.Status}"
                       TextWrapping="Wrap"
                       Margin="0,4,0,0" />
            <TextBlock Grid.Row="15"
                       Text="Re-inspect History"
                       Style="{DynamicResource Text.SectionHeader}"
                       Margin="0,8,0,4" />
            <Grid Grid.Row="16">
              <ListView ItemsSource="{Binding ReinspectComparisons}"
                        MinHeight="120"
                        Style="{DynamicResource ListView.HmiGrid}">
                <ListView.View>
                  <GridView>
                    <GridViewColumn Header="Compared" DisplayMemberBinding="{Binding ComparedAtText}" Width="150" />
                    <GridViewColumn Header="Lot" DisplayMemberBinding="{Binding LotId}" Width="150" />
                    <GridViewColumn Header="Recipe" DisplayMemberBinding="{Binding RecipeText}" Width="150" />
                    <GridViewColumn Header="Status" DisplayMemberBinding="{Binding Status}" Width="100" />
                    <GridViewColumn Header="Judge" DisplayMemberBinding="{Binding JudgmentTransition}" Width="120" />
                    <GridViewColumn Header="Defects" DisplayMemberBinding="{Binding DefectTransition}" Width="90" />
                    <GridViewColumn Header="Cycle" DisplayMemberBinding="{Binding CycleTransition}" Width="160" />
                    <GridViewColumn Header="Persistence" DisplayMemberBinding="{Binding PersistenceStatus}" Width="220" />
                    <GridViewColumn Header="Message" Width="420">
                      <GridViewColumn.CellTemplate>
                        <DataTemplate>
                          <TextBlock Text="{Binding Message}"
                                     TextWrapping="Wrap"
                                     Style="{DynamicResource Text.Status}" />
                        </DataTemplate>
                      </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                  </GridView>
                </ListView.View>
              </ListView>
              <controls:EmptyState HasItems="{Binding HasReinspectComparisons}"
                                   Title="No Re-inspect History"
                                   Detail="Run Re-inspect to store metadata comparison history." />
            </Grid>
          </Grid>

          <Grid Grid.Row="4" Margin="0,8,0,0">
            <ListView ItemsSource="{Binding SelectedResult.Defects}"
                      MinHeight="120"
                      Style="{DynamicResource ListView.HmiGrid}">
              <ListView.View>
                <GridView>
                  <GridViewColumn Header="Type" DisplayMemberBinding="{Binding Type}" Width="110" />
                  <GridViewColumn Header="Score" DisplayMemberBinding="{Binding ScoreText}" Width="90" />
                  <GridViewColumn Header="ROI" DisplayMemberBinding="{Binding RoiId}" Width="110" />
                  <GridViewColumn Header="BBox" DisplayMemberBinding="{Binding BoundingBoxText}" Width="140" />
                  <GridViewColumn Header="Message" DisplayMemberBinding="{Binding Message}" Width="420" />
                </GridView>
              </ListView.View>
            </ListView>
            <controls:EmptyState HasItems="{Binding SelectedResult.HasDefects}"
                                 Title="No Defect Rows"
                                 Detail="{Binding DefectListStatusText}" />
          </Grid>
        </Grid>
      </Border>
    </Grid>
  </ScrollViewer>
</UserControl>
