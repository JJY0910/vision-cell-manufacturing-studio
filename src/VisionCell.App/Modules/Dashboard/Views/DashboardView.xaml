<UserControl x:Class="VisionCell.App.Modules.Dashboard.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:VisionCell.App.Shared.Controls">
  <ScrollViewer VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled">
    <Grid MinWidth="0">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <controls:CommandBar Title="Dashboard"
                           StatusText="{Binding LastSnapshotAt, StringFormat=Last snapshot: {0:yyyy-MM-dd HH:mm:ss}}">
        <controls:CommandBar.CommandContent>
          <WrapPanel Margin="0,0,-8,0">
            <Button Content="Connect"
                    Command="{Binding ConnectCommand}"
                    ToolTip="{Binding ConnectDisabledReason}"
                    Style="{DynamicResource Button.HmiCommand}" />
            <Button Content="Disconnect"
                    Command="{Binding DisconnectCommand}"
                    ToolTip="{Binding DisconnectDisabledReason}"
                    Style="{DynamicResource Button.HmiCommand}"
                    MinWidth="104" />
            <Button Content="Manual"
                    Command="{Binding EnterManualModeCommand}"
                    ToolTip="{Binding EnterManualModeDisabledReason}"
                    Style="{DynamicResource Button.HmiCommand}" />
            <Button Content="Auto"
                    Command="{Binding EnterAutoModeCommand}"
                    ToolTip="{Binding EnterAutoModeDisabledReason}"
                    Style="{DynamicResource Button.HmiCommand}" />
            <Button Content="Refresh"
                    Command="{Binding RefreshCommand}"
                    ToolTip="Refresh the latest controller, safety, axis, and I/O snapshot."
                    Style="{DynamicResource Button.HmiCommand}" />
          </WrapPanel>
        </controls:CommandBar.CommandContent>
      </controls:CommandBar>

      <ItemsControl Grid.Row="1" ItemsSource="{Binding StatusPills}" Margin="0,20,0,8">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <WrapPanel />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <controls:StatusPill />
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <UniformGrid Grid.Row="2" Columns="3" Margin="-8,4,-8,4">
        <controls:KpiCard Title="Equipment Overview"
                          Value="{Binding ConnectionStatus}"
                          Detail="{Binding ControllerLatencyStatus}" />
        <controls:KpiCard Title="Safety Summary"
                          Value="{Binding SafetyStatus}"
                          Detail="Safety inputs" />
        <controls:KpiCard Title="Camera / Recipe"
                          Value="{Binding CameraStatus}"
                          Detail="{Binding ActiveRecipeStatus}" />
      </UniformGrid>

      <Grid Grid.Row="3" Margin="0,8,0,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="2*" MinWidth="0" />
          <ColumnDefinition Width="*" MinWidth="0" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Border Style="{DynamicResource Card.Panel}" Margin="0,8,8,8">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Text="Axis Snapshot" Style="{DynamicResource Text.CardTitle}" />
            <ItemsControl Grid.Row="1" ItemsSource="{Binding Axes}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <UniformGrid Columns="4" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <controls:AxisCard />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </Grid>
        </Border>

        <Border Grid.Column="1" Style="{DynamicResource Card.Panel}" Margin="8,8,0,8">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Text="I/O Snapshot" Style="{DynamicResource Text.CardTitle}" />
            <ListView Grid.Row="1"
                      ItemsSource="{Binding IoBits}"
                      Style="{DynamicResource ListView.HmiGrid}">
              <ListView.View>
                <GridView>
                  <GridViewColumn Header="Address" DisplayMemberBinding="{Binding Address}" Width="70" />
                  <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="170" />
                  <GridViewColumn Header="Dir" DisplayMemberBinding="{Binding Direction}" Width="56" />
                  <GridViewColumn Header="State" Width="112">
                    <GridViewColumn.CellTemplate>
                      <DataTemplate>
                        <controls:IoBitIndicator />
                      </DataTemplate>
                    </GridViewColumn.CellTemplate>
                  </GridViewColumn>
                </GridView>
              </ListView.View>
            </ListView>
          </Grid>
        </Border>

        <Border Grid.Row="1" Grid.ColumnSpan="2" Style="{DynamicResource Card.Panel}" Margin="0,8,0,0">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Text="Command Interlocks" Style="{DynamicResource Text.CardTitle}" />
            <ItemsControl Grid.Row="1" ItemsSource="{Binding CommandAvailabilities}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <UniformGrid Columns="5" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Style="{DynamicResource Card.Compact}" ToolTip="{Binding Reason}">
                    <StackPanel>
                      <TextBlock Text="{Binding Label}" Style="{DynamicResource Text.StatusStrong}" />
                      <TextBlock Text="{Binding State}" Style="{DynamicResource Text.MetricLabel}" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </Grid>
        </Border>
      </Grid>
    </Grid>
  </ScrollViewer>
</UserControl>
