<UserControl x:Class="VisionCell.App.Modules.Equipment.Views.EquipmentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:VisionCell.App.Shared.Controls">
  <ScrollViewer VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled">
    <Grid MinWidth="0">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <controls:CommandBar Title="Equipment"
                           StatusText="{Binding LastSnapshotText}">
        <controls:CommandBar.CommandContent>
          <Button Content="Refresh"
                  Command="{Binding RefreshCommand}"
                  ToolTip="Refresh controller, safety, fault, I/O, and event state."
                  Style="{DynamicResource Button.HmiCommand}" />
        </controls:CommandBar.CommandContent>
      </controls:CommandBar>

      <UniformGrid Grid.Row="1" Columns="3" Margin="-8,20,-8,4">
        <Border Style="{DynamicResource Card.Panel}">
          <StackPanel>
            <TextBlock Text="Controller" Style="{DynamicResource Text.CardTitle}" />
            <TextBlock Text="{Binding ConnectionStatus}" Style="{DynamicResource Text.MetricValue}" />
            <TextBlock Text="{Binding ModeStatus, StringFormat=Mode {0}}"
                       Style="{DynamicResource Text.StatusStrong}"
                       Margin="0,8,0,0" />
          </StackPanel>
        </Border>
        <Border Style="{DynamicResource Card.Panel}">
          <StackPanel>
            <TextBlock Text="Safety / Interlock" Style="{DynamicResource Text.CardTitle}" />
            <TextBlock Text="{Binding SafetyStatus}"
                       TextWrapping="Wrap"
                       Style="{DynamicResource Text.StatusStrong}" />
          </StackPanel>
        </Border>
        <Border Style="{DynamicResource Card.Panel}">
          <StackPanel>
            <TextBlock Text="Camera / Alarm" Style="{DynamicResource Text.CardTitle}" />
            <TextBlock Text="{Binding CameraStatus}"
                       Style="{DynamicResource Text.StatusStrong}"
                       Margin="0,0,0,8" />
            <TextBlock Text="{Binding AlarmStatus}"
                       TextWrapping="Wrap"
                       Style="{DynamicResource Text.Status}" />
          </StackPanel>
        </Border>
      </UniformGrid>

      <Grid Grid.Row="2" Margin="0,8,0,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="3*" />
          <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>
        <Border Style="{DynamicResource Card.Panel}" Margin="0,0,8,0">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Text="Fault Injection" Style="{DynamicResource Text.CardTitle}" />
            <TextBlock Grid.Row="1"
                       Text="{Binding InjectionStatus}"
                       TextWrapping="Wrap"
                       Style="{DynamicResource Text.Status}"
                       Margin="0,0,0,12" />
            <UniformGrid Grid.Row="2" Columns="2" Margin="0,0,0,12">
              <TextBlock Text="{Binding FaultSummaryText}" Style="{DynamicResource Text.StatusStrong}" />
              <TextBlock Text="{Binding IoSummaryText}" Style="{DynamicResource Text.StatusStrong}" />
            </UniformGrid>
            <WrapPanel Grid.Row="3">
              <Button Content="EStop On" Command="{Binding InjectEmergencyStopCommand}" ToolTip="{Binding FaultInjectionDisabledReason}" Style="{DynamicResource Button.HmiCommand.Compact}" MinWidth="92" />
              <Button Content="EStop Off" Command="{Binding ClearEmergencyStopCommand}" ToolTip="{Binding FaultInjectionDisabledReason}" Style="{DynamicResource Button.HmiCommand.Compact}" MinWidth="92" />
              <Button Content="Door Open" Command="{Binding OpenDoorCommand}" ToolTip="{Binding FaultInjectionDisabledReason}" Style="{DynamicResource Button.HmiCommand.Compact}" MinWidth="96" />
              <Button Content="Door Close" Command="{Binding CloseDoorCommand}" ToolTip="{Binding FaultInjectionDisabledReason}" Style="{DynamicResource Button.HmiCommand.Compact}" MinWidth="96" />
              <Button Content="Air Low" Command="{Binding DropAirPressureCommand}" ToolTip="{Binding FaultInjectionDisabledReason}" Style="{DynamicResource Button.HmiCommand.Compact}" MinWidth="88" />
              <Button Content="Air OK" Command="{Binding RestoreAirPressureCommand}" ToolTip="{Binding FaultInjectionDisabledReason}" Style="{DynamicResource Button.HmiCommand.Compact}" />
              <Button Content="Vacuum Loss" Command="{Binding DropVacuumCommand}" ToolTip="{Binding FaultInjectionDisabledReason}" Style="{DynamicResource Button.HmiCommand.Compact}" MinWidth="108" />
              <Button Content="Vacuum OK" Command="{Binding RestoreVacuumCommand}" ToolTip="{Binding FaultInjectionDisabledReason}" Style="{DynamicResource Button.HmiCommand.Compact}" MinWidth="98" />
              <Button Content="Camera Not Ready" Command="{Binding DisableCameraReadyCommand}" ToolTip="{Binding FaultInjectionDisabledReason}" Style="{DynamicResource Button.HmiCommand.Compact}" MinWidth="138" />
              <Button Content="Camera Ready" Command="{Binding RestoreCameraReadyCommand}" ToolTip="{Binding FaultInjectionDisabledReason}" Style="{DynamicResource Button.HmiCommand.Compact}" MinWidth="116" />
              <Button Content="Servo Alarm" Command="{Binding InjectServoAlarmCommand}" ToolTip="{Binding FaultInjectionDisabledReason}" Style="{DynamicResource Button.HmiCommand.Compact}" MinWidth="108" />
              <Button Content="Servo Clear" Command="{Binding ClearServoAlarmCommand}" ToolTip="{Binding FaultInjectionDisabledReason}" Style="{DynamicResource Button.HmiCommand.Compact}" MinWidth="104" />
              <Button Content="Clear All" Command="{Binding ClearAllFaultsCommand}" ToolTip="{Binding FaultInjectionDisabledReason}" Style="{DynamicResource Button.HmiCommand.Compact}" MinWidth="96" />
            </WrapPanel>
          </Grid>
        </Border>

        <Border Grid.Column="1" Style="{DynamicResource Card.Panel}" Margin="8,0,0,0">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="150" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="180" />
            </Grid.RowDefinitions>
            <TextBlock Text="Fault State" Style="{DynamicResource Text.CardTitle}" />
            <ListView Grid.Row="1"
                      ItemsSource="{Binding Faults}"
                      Style="{DynamicResource ListView.HmiGrid}">
              <ListView.View>
                <GridView>
                  <GridViewColumn Header="Signal" DisplayMemberBinding="{Binding Name}" Width="132" />
                  <GridViewColumn Header="State" DisplayMemberBinding="{Binding State}" Width="96" />
                  <GridViewColumn Header="Active" DisplayMemberBinding="{Binding IsActive}" Width="64" />
                </GridView>
              </ListView.View>
            </ListView>
            <TextBlock Grid.Row="2"
                       Text="Interlock Impact"
                       Style="{DynamicResource Text.CardTitle}"
                       Margin="0,14,0,0" />
            <TextBlock Grid.Row="3"
                       Text="{Binding InterlockImpactSummaryText}"
                       Style="{DynamicResource Text.Status}"
                       Margin="0,0,0,8" />
            <ListView Grid.Row="4"
                      ItemsSource="{Binding InterlockImpacts}"
                      Style="{DynamicResource ListView.HmiGrid}">
              <ListView.View>
                <GridView>
                  <GridViewColumn Header="Command" Width="110">
                    <GridViewColumn.CellTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding CommandName}"
                                   TextWrapping="Wrap"
                                   Style="{DynamicResource Text.StatusStrong}" />
                      </DataTemplate>
                    </GridViewColumn.CellTemplate>
                  </GridViewColumn>
                  <GridViewColumn Header="State" DisplayMemberBinding="{Binding State}" Width="68" />
                  <GridViewColumn Header="Reason" Width="220">
                    <GridViewColumn.CellTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding Reason}"
                                   TextWrapping="Wrap"
                                   Style="{DynamicResource Text.Status}" />
                      </DataTemplate>
                    </GridViewColumn.CellTemplate>
                  </GridViewColumn>
                </GridView>
              </ListView.View>
            </ListView>
          </Grid>
        </Border>
      </Grid>

      <Grid Grid.Row="3" Margin="0,16,0,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="3*" />
          <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>
        <Border Style="{DynamicResource Card.Panel}" Margin="0,0,8,0">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Text="I/O Monitor" Style="{DynamicResource Text.CardTitle}" />
            <controls:EmptyState Grid.Row="1"
                                 HasItems="{Binding HasIoBits}"
                                 Title="No I/O Snapshot"
                                 Detail="{Binding LastSnapshotText}"
                                 Margin="0,0,0,8" />
            <ListView Grid.Row="2"
                      ItemsSource="{Binding IoBits}"
                      Style="{DynamicResource ListView.HmiGrid}">
              <ListView.View>
                <GridView>
                  <GridViewColumn Header="Address" DisplayMemberBinding="{Binding Address}" Width="78" />
                  <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="180" />
                  <GridViewColumn Header="Direction" DisplayMemberBinding="{Binding Direction}" Width="84" />
                  <GridViewColumn Header="State" Width="124">
                    <GridViewColumn.CellTemplate>
                      <DataTemplate>
                        <controls:IoBitIndicator />
                      </DataTemplate>
                    </GridViewColumn.CellTemplate>
                  </GridViewColumn>
                </GridView>
              </ListView.View>
            </ListView>
          </Grid>
        </Border>

        <Border Grid.Column="1" Style="{DynamicResource Card.Panel}" Margin="8,0,0,0">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="170" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="190" />
            </Grid.RowDefinitions>
            <TextBlock Text="Fault Events" Style="{DynamicResource Text.CardTitle}" />
            <controls:EmptyState Grid.Row="1"
                                 HasItems="{Binding HasEvents}"
                                 Title="No Fault Events"
                                 Detail="Refresh equipment state or inject a simulator fault to record an operator-visible event."
                                 Margin="0,0,0,8" />
            <ListView Grid.Row="2"
                      ItemsSource="{Binding Events}"
                      Style="{DynamicResource ListView.HmiGrid}">
              <ListView.View>
                <GridView>
                  <GridViewColumn Header="Time" DisplayMemberBinding="{Binding CreatedAt, StringFormat={}{0:HH:mm:ss}}" Width="72" />
                  <GridViewColumn Header="Severity" DisplayMemberBinding="{Binding Severity}" Width="78" />
                  <GridViewColumn Header="Event" DisplayMemberBinding="{Binding EventType}" Width="108" />
                  <GridViewColumn Header="Message" DisplayMemberBinding="{Binding Message}" Width="240" />
                </GridView>
              </ListView.View>
            </ListView>
            <Grid Grid.Row="3" Margin="0,16,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBlock Text="I/O Transitions" Style="{DynamicResource Text.CardTitle}" />
              <TextBlock Grid.Column="1"
                         Text="{Binding IoTransitionStatus}"
                         Style="{DynamicResource Text.Status}"
                         HorizontalAlignment="Right"
                         Margin="16,0,12,0" />
              <Button Grid.Column="2"
                      Content="Refresh"
                      Command="{Binding RefreshIoTransitionHistoryCommand}"
                      ToolTip="Reload recent simulator I/O transition history."
                      Style="{DynamicResource Button.HmiCommand.Compact}"
                      MinWidth="84" />
            </Grid>
            <controls:EmptyState Grid.Row="4"
                                 HasItems="{Binding HasIoTransitions}"
                                 Title="No I/O Transitions"
                                 Detail="{Binding IoTransitionStatus}"
                                 Margin="0,0,0,8" />
            <ListView Grid.Row="5"
                      ItemsSource="{Binding IoTransitions}"
                      Style="{DynamicResource ListView.HmiGrid}">
              <ListView.View>
                <GridView>
                  <GridViewColumn Header="Time" DisplayMemberBinding="{Binding TimeText}" Width="72" />
                  <GridViewColumn Header="Address" DisplayMemberBinding="{Binding Address}" Width="74" />
                  <GridViewColumn Header="Name" DisplayMemberBinding="{Binding Name}" Width="154" />
                  <GridViewColumn Header="Before" DisplayMemberBinding="{Binding PreviousState}" Width="92" />
                  <GridViewColumn Header="After" DisplayMemberBinding="{Binding CurrentState}" Width="92" />
                  <GridViewColumn Header="Source" DisplayMemberBinding="{Binding Source}" Width="184" />
                </GridView>
              </ListView.View>
            </ListView>
          </Grid>
        </Border>
      </Grid>
    </Grid>
  </ScrollViewer>
</UserControl>
