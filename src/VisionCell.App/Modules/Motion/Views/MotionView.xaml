<UserControl x:Class="VisionCell.App.Modules.Motion.Views.MotionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:VisionCell.App.Shared.Controls">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <DockPanel>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
          <Button Content="Refresh Snapshot"
                  Command="{Binding RefreshSnapshotCommand}"
                  ToolTip="Refresh controller, servo, axis, and command interlock state."
                  Height="36"
                  MinWidth="132"
                  Margin="0,0,8,0" />
          <Button Content="Refresh History"
                  Command="{Binding RefreshHistoryCommand}"
                  ToolTip="Reload recent motion command records from the local history store."
                  Height="36"
                  MinWidth="126" />
        </StackPanel>
        <StackPanel>
          <TextBlock Text="Motion" Style="{DynamicResource Text.PageTitle}" />
          <TextBlock Text="{Binding CommandStatus}"
                     Style="{DynamicResource Text.Status}"
                     Margin="0,4,0,0" />
        </StackPanel>
      </DockPanel>

      <UniformGrid Grid.Row="1" Columns="4" Margin="-8,12,-8,4">
        <Border Style="{DynamicResource Card.Panel}">
          <StackPanel>
            <TextBlock Text="Controller" Style="{DynamicResource Text.CardTitle}" />
            <TextBlock Text="{Binding ControllerStatus}" Style="{DynamicResource Text.MetricValue}" />
          </StackPanel>
        </Border>
        <Border Style="{DynamicResource Card.Panel}">
          <StackPanel>
            <TextBlock Text="Servo" Style="{DynamicResource Text.CardTitle}" />
            <TextBlock Text="{Binding ServoStatus}" Style="{DynamicResource Text.MetricValue}" />
          </StackPanel>
        </Border>
        <Border Style="{DynamicResource Card.Panel}">
          <StackPanel>
            <TextBlock Text="Axis State" Style="{DynamicResource Text.CardTitle}" />
            <TextBlock Text="{Binding AxisStatus}"
                       Style="{DynamicResource Text.StatusStrong}" />
          </StackPanel>
        </Border>
        <Border Style="{DynamicResource Card.Panel}">
          <StackPanel>
            <TextBlock Text="Last Command" Style="{DynamicResource Text.CardTitle}" />
            <TextBlock Text="{Binding LastCommandCorrelationId}"
                       Style="{DynamicResource Text.StatusStrong}"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>
      </UniformGrid>

      <Border Grid.Row="2" Style="{DynamicResource Card.Panel}" Margin="0,8,0,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <TextBlock Text="Axis Snapshot" Style="{DynamicResource Text.CardTitle}" />
          <ItemsControl Grid.Row="1" ItemsSource="{Binding Axes}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <UniformGrid Columns="4" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <controls:AxisCard />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </Grid>
      </Border>

      <Border Grid.Row="3" Style="{DynamicResource Card.Panel}" Margin="0,8,0,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <TextBlock Text="Motion Commands" Style="{DynamicResource Text.CardTitle}" />
          <WrapPanel Grid.Row="1">
            <Button Content="Servo On"
                    Command="{Binding ServoOnCommand}"
                    ToolTip="{Binding ServoOnDisabledReason}"
                    Style="{DynamicResource Button.HmiCommand}" />
            <Button Content="Servo Off"
                    Command="{Binding ServoOffCommand}"
                    ToolTip="{Binding ServoOffDisabledReason}"
                    Style="{DynamicResource Button.HmiCommand}" />
            <Button Content="Home All"
                    Command="{Binding HomeCommand}"
                    ToolTip="{Binding HomeDisabledReason}"
                    Style="{DynamicResource Button.HmiCommand}" />
            <Button Content="Stop"
                    Command="{Binding StopCommand}"
                    ToolTip="{Binding StopDisabledReason}"
                    Style="{DynamicResource Button.HmiCommand}" />
          </WrapPanel>
          <WrapPanel Grid.Row="2" Margin="0,4,0,0">
            <StackPanel Width="112" Style="{DynamicResource Form.Field}">
              <TextBlock Text="Jog Axis" Style="{DynamicResource Text.MetricLabel}" />
              <ComboBox ItemsSource="{Binding JogAxisOptions}"
                        SelectedItem="{Binding SelectedJogAxis}"
                        Style="{DynamicResource ComboBox.HmiInput}" />
            </StackPanel>
            <StackPanel Width="112" Style="{DynamicResource Form.Field}">
              <TextBlock Text="Step" Style="{DynamicResource Text.MetricLabel}" />
              <TextBox Text="{Binding JogStepText, UpdateSourceTrigger=PropertyChanged}"
                       Style="{DynamicResource TextBox.HmiInput}" />
            </StackPanel>
            <Button Content="Jog -"
                    Command="{Binding JogNegativeCommand}"
                    ToolTip="{Binding JogDisabledReason}"
                    Style="{DynamicResource Button.HmiCommand.Compact}" />
            <Button Content="Jog +"
                    Command="{Binding JogPositiveCommand}"
                    ToolTip="{Binding JogDisabledReason}"
                    Style="{DynamicResource Button.HmiCommand.Compact}" />
          </WrapPanel>
          <WrapPanel Grid.Row="3" Margin="0,4,0,0">
            <StackPanel Width="96" Style="{DynamicResource Form.Field}">
              <TextBlock Text="X Target" Style="{DynamicResource Text.MetricLabel}" />
              <TextBox Text="{Binding MoveTargetXText, UpdateSourceTrigger=PropertyChanged}"
                       Style="{DynamicResource TextBox.HmiInput}" />
            </StackPanel>
            <StackPanel Width="96" Style="{DynamicResource Form.Field}">
              <TextBlock Text="Y Target" Style="{DynamicResource Text.MetricLabel}" />
              <TextBox Text="{Binding MoveTargetYText, UpdateSourceTrigger=PropertyChanged}"
                       Style="{DynamicResource TextBox.HmiInput}" />
            </StackPanel>
            <StackPanel Width="96" Style="{DynamicResource Form.Field}">
              <TextBlock Text="Z Target" Style="{DynamicResource Text.MetricLabel}" />
              <TextBox Text="{Binding MoveTargetZText, UpdateSourceTrigger=PropertyChanged}"
                       Style="{DynamicResource TextBox.HmiInput}" />
            </StackPanel>
            <StackPanel Width="112" Style="{DynamicResource Form.Field}">
              <TextBlock Text="Theta Target" Style="{DynamicResource Text.MetricLabel}" />
              <TextBox Text="{Binding MoveTargetThetaText, UpdateSourceTrigger=PropertyChanged}"
                       Style="{DynamicResource TextBox.HmiInput}" />
            </StackPanel>
            <Button Content="Move Absolute"
                    Command="{Binding MoveAbsoluteCommand}"
                    ToolTip="{Binding MoveAbsoluteDisabledReason}"
                    Style="{DynamicResource Button.HmiCommand.Compact}"
                    MinWidth="128" />
          </WrapPanel>
          <WrapPanel Grid.Row="4" Margin="0,4,0,0">
            <StackPanel Width="156" Style="{DynamicResource Form.Field}">
              <TextBlock Text="Profile" Style="{DynamicResource Text.MetricLabel}" />
              <ComboBox ItemsSource="{Binding MoveProfilePresets}"
                        SelectedItem="{Binding SelectedMoveProfilePreset}"
                        DisplayMemberPath="Name"
                        Style="{DynamicResource ComboBox.HmiInput}" />
            </StackPanel>
            <StackPanel Width="96" Style="{DynamicResource Form.Field}">
              <TextBlock Text="Velocity" Style="{DynamicResource Text.MetricLabel}" />
              <TextBox Text="{Binding MoveVelocityText, UpdateSourceTrigger=PropertyChanged}"
                       Style="{DynamicResource TextBox.HmiInput}" />
            </StackPanel>
            <StackPanel Width="96" Style="{DynamicResource Form.Field}">
              <TextBlock Text="Accel" Style="{DynamicResource Text.MetricLabel}" />
              <TextBox Text="{Binding MoveAccelerationText, UpdateSourceTrigger=PropertyChanged}"
                       Style="{DynamicResource TextBox.HmiInput}" />
            </StackPanel>
            <StackPanel Width="96" Style="{DynamicResource Form.Field}">
              <TextBlock Text="Decel" Style="{DynamicResource Text.MetricLabel}" />
              <TextBox Text="{Binding MoveDecelerationText, UpdateSourceTrigger=PropertyChanged}"
                       Style="{DynamicResource TextBox.HmiInput}" />
            </StackPanel>
            <StackPanel Width="96" Style="{DynamicResource Form.Field}">
              <TextBlock Text="Jerk" Style="{DynamicResource Text.MetricLabel}" />
              <TextBox Text="{Binding MoveJerkText, UpdateSourceTrigger=PropertyChanged}"
                       Style="{DynamicResource TextBox.HmiInput}" />
            </StackPanel>
            <StackPanel Width="104" Style="{DynamicResource Form.Field}">
              <TextBlock Text="Tolerance" Style="{DynamicResource Text.MetricLabel}" />
              <TextBox Text="{Binding MoveArrivalToleranceText, UpdateSourceTrigger=PropertyChanged}"
                       Style="{DynamicResource TextBox.HmiInput}" />
            </StackPanel>
          </WrapPanel>
          <TextBlock Grid.Row="6"
                     Text="{Binding LastSnapshotAt, StringFormat=Last snapshot: {0:yyyy-MM-dd HH:mm:ss}, TargetNullValue=Last snapshot: -}"
                     Style="{DynamicResource Text.Status}"
                     Margin="0,4,0,0" />
        </Grid>
      </Border>

      <Border Grid.Row="4" Style="{DynamicResource Card.Panel}" Margin="0,8,0,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <DockPanel>
            <TextBlock Text="Recent Motion Commands" Style="{DynamicResource Text.CardTitle}" />
            <TextBlock DockPanel.Dock="Right"
                       Text="{Binding HistoryStatus}"
                       Style="{DynamicResource Text.Status}" />
          </DockPanel>
          <ListView Grid.Row="1"
                    ItemsSource="{Binding RecentCommands}"
                    Style="{DynamicResource ListView.HmiGrid}">
            <ListView.View>
              <GridView>
                <GridViewColumn Header="Time" DisplayMemberBinding="{Binding CreatedAtText}" Width="150" />
                <GridViewColumn Header="Command" DisplayMemberBinding="{Binding CommandName}" Width="130" />
                <GridViewColumn Header="Axis" DisplayMemberBinding="{Binding AxisId}" Width="60" />
                <GridViewColumn Header="Status" DisplayMemberBinding="{Binding StatusText}" Width="90" />
                <GridViewColumn Header="Error" DisplayMemberBinding="{Binding ErrorCode}" Width="86" />
                <GridViewColumn Header="Elapsed" DisplayMemberBinding="{Binding ElapsedText}" Width="86" />
                <GridViewColumn Header="Correlation" DisplayMemberBinding="{Binding CorrelationShort}" Width="110" />
                <GridViewColumn Header="Message" DisplayMemberBinding="{Binding Message}" Width="360" />
              </GridView>
            </ListView.View>
          </ListView>
        </Grid>
      </Border>
    </Grid>
  </ScrollViewer>
</UserControl>
