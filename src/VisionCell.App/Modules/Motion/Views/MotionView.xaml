<UserControl x:Class="VisionCell.App.Modules.Motion.Views.MotionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <DockPanel>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
          <Button Content="Refresh Snapshot"
                  Command="{Binding RefreshSnapshotCommand}"
                  Height="36"
                  MinWidth="132"
                  Margin="0,0,8,0" />
          <Button Content="Refresh History"
                  Command="{Binding RefreshHistoryCommand}"
                  Height="36"
                  MinWidth="126" />
        </StackPanel>
        <StackPanel>
          <TextBlock Text="Motion" Style="{DynamicResource Text.PageTitle}" />
          <TextBlock Text="{Binding CommandStatus}"
                     Style="{DynamicResource Text.Status}"
                     Margin="0,4,0,0" />
        </StackPanel>
      </DockPanel>

      <UniformGrid Grid.Row="1" Columns="4" Margin="-8,12,-8,4">
        <Border Style="{DynamicResource Card.Panel}">
          <StackPanel>
            <TextBlock Text="Controller" Style="{DynamicResource Text.CardTitle}" />
            <TextBlock Text="{Binding ControllerStatus}" Style="{DynamicResource Text.MetricValue}" />
          </StackPanel>
        </Border>
        <Border Style="{DynamicResource Card.Panel}">
          <StackPanel>
            <TextBlock Text="Servo" Style="{DynamicResource Text.CardTitle}" />
            <TextBlock Text="{Binding ServoStatus}" Style="{DynamicResource Text.MetricValue}" />
          </StackPanel>
        </Border>
        <Border Style="{DynamicResource Card.Panel}">
          <StackPanel>
            <TextBlock Text="Axis State" Style="{DynamicResource Text.CardTitle}" />
            <TextBlock Text="{Binding AxisStatus}"
                       Style="{DynamicResource Text.StatusStrong}" />
          </StackPanel>
        </Border>
        <Border Style="{DynamicResource Card.Panel}">
          <StackPanel>
            <TextBlock Text="Last Command" Style="{DynamicResource Text.CardTitle}" />
            <TextBlock Text="{Binding LastCommandCorrelationId}"
                       Style="{DynamicResource Text.StatusStrong}"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>
      </UniformGrid>

      <Border Grid.Row="2" Style="{DynamicResource Card.Panel}" Margin="0,8,0,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <TextBlock Text="Axis Snapshot" Style="{DynamicResource Text.CardTitle}" />
          <ItemsControl Grid.Row="1" ItemsSource="{Binding Axes}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <UniformGrid Columns="4" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Style="{DynamicResource Card.Compact}">
                  <StackPanel>
                    <TextBlock Text="{Binding Label}" Style="{DynamicResource Text.MetricValue}" />
                    <TextBlock Text="{Binding MotionState}"
                               Style="{DynamicResource Text.StatusStrong}"
                               Margin="0,8,0,0" />
                    <TextBlock Text="{Binding PositionText}"
                               Style="{DynamicResource Text.Status}"
                               Margin="0,8,0,0" />
                    <TextBlock Text="{Binding TargetText}"
                               Style="{DynamicResource Text.Status}" />
                    <TextBlock Text="{Binding SoftLimitText}"
                               Style="{DynamicResource Text.MetricLabel}"
                               Margin="0,8,0,0" />
                    <TextBlock Text="{Binding HomeState}"
                               Style="{DynamicResource Text.MetricLabel}" />
                    <TextBlock Text="{Binding ServoState}"
                               Style="{DynamicResource Text.MetricLabel}" />
                    <TextBlock Text="{Binding Alarm, StringFormat=Alarm {0}}"
                               Style="{DynamicResource Text.MetricLabel}" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </Grid>
      </Border>

      <Border Grid.Row="3" Style="{DynamicResource Card.Panel}" Margin="0,8,0,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <TextBlock Text="Motion Commands" Style="{DynamicResource Text.CardTitle}" />
          <WrapPanel Grid.Row="1">
            <Button Content="Servo On"
                    Command="{Binding ServoOnCommand}"
                    ToolTip="{Binding ServoOnDisabledReason}"
                    Height="36"
                    MinWidth="94"
                    Margin="0,0,8,8" />
            <Button Content="Servo Off"
                    Command="{Binding ServoOffCommand}"
                    ToolTip="{Binding ServoOffDisabledReason}"
                    Height="36"
                    MinWidth="94"
                    Margin="0,0,8,8" />
            <Button Content="Home All"
                    Command="{Binding HomeCommand}"
                    ToolTip="{Binding HomeDisabledReason}"
                    Height="36"
                    MinWidth="94"
                    Margin="0,0,8,8" />
            <Button Content="Stop"
                    Command="{Binding StopCommand}"
                    ToolTip="{Binding StopDisabledReason}"
                    Height="36"
                    MinWidth="84"
                    Margin="0,0,8,8" />
          </WrapPanel>
          <Grid Grid.Row="2" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="96" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="96" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Jog Axis"
                       Style="{DynamicResource Text.MetricLabel}"
                       VerticalAlignment="Center"
                       Margin="0,0,8,8" />
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding JogAxisOptions}"
                      SelectedItem="{Binding SelectedJogAxis}"
                      Height="32"
                      Margin="0,0,12,8" />
            <TextBlock Grid.Column="2"
                       Text="Step"
                       Style="{DynamicResource Text.MetricLabel}"
                       VerticalAlignment="Center"
                       Margin="0,0,8,8" />
            <TextBox Grid.Column="3"
                     Text="{Binding JogStepText, UpdateSourceTrigger=PropertyChanged}"
                     Height="32"
                     Margin="0,0,12,8" />
            <Button Grid.Column="4"
                    Content="Jog -"
                    Command="{Binding JogNegativeCommand}"
                    ToolTip="{Binding JogDisabledReason}"
                    Height="32"
                    MinWidth="76"
                    Margin="0,0,8,8" />
            <Button Grid.Column="5"
                    Content="Jog +"
                    Command="{Binding JogPositiveCommand}"
                    ToolTip="{Binding JogDisabledReason}"
                    Height="32"
                    MinWidth="76"
                    Margin="0,0,8,8" />
          </Grid>
          <Grid Grid.Row="3" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="88" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="88" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="88" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="88" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="X"
                       Style="{DynamicResource Text.MetricLabel}"
                       VerticalAlignment="Center"
                       Margin="0,0,8,8" />
            <TextBox Grid.Column="1"
                     Text="{Binding MoveTargetXText, UpdateSourceTrigger=PropertyChanged}"
                     Height="32"
                     Margin="0,0,12,8" />
            <TextBlock Grid.Column="2"
                       Text="Y"
                       Style="{DynamicResource Text.MetricLabel}"
                       VerticalAlignment="Center"
                       Margin="0,0,8,8" />
            <TextBox Grid.Column="3"
                     Text="{Binding MoveTargetYText, UpdateSourceTrigger=PropertyChanged}"
                     Height="32"
                     Margin="0,0,12,8" />
            <TextBlock Grid.Column="4"
                       Text="Z"
                       Style="{DynamicResource Text.MetricLabel}"
                       VerticalAlignment="Center"
                       Margin="0,0,8,8" />
            <TextBox Grid.Column="5"
                     Text="{Binding MoveTargetZText, UpdateSourceTrigger=PropertyChanged}"
                     Height="32"
                     Margin="0,0,12,8" />
            <TextBlock Grid.Column="6"
                       Text="Theta"
                       Style="{DynamicResource Text.MetricLabel}"
                       VerticalAlignment="Center"
                       Margin="0,0,8,8" />
            <TextBox Grid.Column="7"
                     Text="{Binding MoveTargetThetaText, UpdateSourceTrigger=PropertyChanged}"
                     Height="32"
                     Margin="0,0,12,8" />
            <Button Grid.Column="8"
                    Content="Move Absolute"
                    Command="{Binding MoveAbsoluteCommand}"
                    ToolTip="{Binding MoveAbsoluteDisabledReason}"
                    Height="32"
                    MinWidth="120"
                    Margin="0,0,8,8" />
          </Grid>
          <Grid Grid.Row="4" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="156" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Profile"
                       Style="{DynamicResource Text.MetricLabel}"
                       VerticalAlignment="Center"
                       Margin="0,0,8,8" />
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding MoveProfilePresets}"
                      SelectedItem="{Binding SelectedMoveProfilePreset}"
                      DisplayMemberPath="Name"
                      Height="32"
                      Margin="0,0,12,8" />
          </Grid>
          <Grid Grid.Row="5" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="88" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="88" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="88" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="88" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="88" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Velocity"
                       Style="{DynamicResource Text.MetricLabel}"
                       VerticalAlignment="Center"
                       Margin="0,0,8,8" />
            <TextBox Grid.Column="1"
                     Text="{Binding MoveVelocityText, UpdateSourceTrigger=PropertyChanged}"
                     Height="32"
                     Margin="0,0,12,8" />
            <TextBlock Grid.Column="2"
                       Text="Accel"
                       Style="{DynamicResource Text.MetricLabel}"
                       VerticalAlignment="Center"
                       Margin="0,0,8,8" />
            <TextBox Grid.Column="3"
                     Text="{Binding MoveAccelerationText, UpdateSourceTrigger=PropertyChanged}"
                     Height="32"
                     Margin="0,0,12,8" />
            <TextBlock Grid.Column="4"
                       Text="Decel"
                       Style="{DynamicResource Text.MetricLabel}"
                       VerticalAlignment="Center"
                       Margin="0,0,8,8" />
            <TextBox Grid.Column="5"
                     Text="{Binding MoveDecelerationText, UpdateSourceTrigger=PropertyChanged}"
                     Height="32"
                     Margin="0,0,12,8" />
            <TextBlock Grid.Column="6"
                       Text="Jerk"
                       Style="{DynamicResource Text.MetricLabel}"
                       VerticalAlignment="Center"
                       Margin="0,0,8,8" />
            <TextBox Grid.Column="7"
                     Text="{Binding MoveJerkText, UpdateSourceTrigger=PropertyChanged}"
                     Height="32"
                     Margin="0,0,12,8" />
            <TextBlock Grid.Column="8"
                       Text="Tol"
                       Style="{DynamicResource Text.MetricLabel}"
                       VerticalAlignment="Center"
                       Margin="0,0,8,8" />
            <TextBox Grid.Column="9"
                     Text="{Binding MoveArrivalToleranceText, UpdateSourceTrigger=PropertyChanged}"
                     Height="32"
                     Margin="0,0,12,8" />
          </Grid>
          <TextBlock Grid.Row="6"
                     Text="{Binding LastSnapshotAt, StringFormat=Last snapshot: {0:yyyy-MM-dd HH:mm:ss}, TargetNullValue=Last snapshot: -}"
                     Style="{DynamicResource Text.Status}"
                     Margin="0,4,0,0" />
        </Grid>
      </Border>

      <Border Grid.Row="4" Style="{DynamicResource Card.Panel}" Margin="0,8,0,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <DockPanel>
            <TextBlock Text="Recent Motion Commands" Style="{DynamicResource Text.CardTitle}" />
            <TextBlock DockPanel.Dock="Right"
                       Text="{Binding HistoryStatus}"
                       Style="{DynamicResource Text.Status}" />
          </DockPanel>
          <ListView Grid.Row="1"
                    ItemsSource="{Binding RecentCommands}"
                    Background="{DynamicResource Brush.PanelAlt}"
                    BorderThickness="0"
                    Foreground="{DynamicResource Brush.TextPrimary}">
            <ListView.View>
              <GridView>
                <GridViewColumn Header="Time" DisplayMemberBinding="{Binding CreatedAtText}" Width="150" />
                <GridViewColumn Header="Command" DisplayMemberBinding="{Binding CommandName}" Width="130" />
                <GridViewColumn Header="Axis" DisplayMemberBinding="{Binding AxisId}" Width="60" />
                <GridViewColumn Header="Status" DisplayMemberBinding="{Binding StatusText}" Width="90" />
                <GridViewColumn Header="Error" DisplayMemberBinding="{Binding ErrorCode}" Width="86" />
                <GridViewColumn Header="Elapsed" DisplayMemberBinding="{Binding ElapsedText}" Width="86" />
                <GridViewColumn Header="Correlation" DisplayMemberBinding="{Binding CorrelationShort}" Width="110" />
                <GridViewColumn Header="Message" DisplayMemberBinding="{Binding Message}" Width="360" />
              </GridView>
            </ListView.View>
          </ListView>
        </Grid>
      </Border>
    </Grid>
  </ScrollViewer>
</UserControl>
