<UserControl x:Class="VisionCell.App.Modules.Motion.Views.MotionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <DockPanel>
        <Button DockPanel.Dock="Right"
                Content="Refresh History"
                Command="{Binding RefreshHistoryCommand}"
                Height="36"
                MinWidth="126" />
        <StackPanel>
          <TextBlock Text="Motion" Style="{DynamicResource Text.PageTitle}" />
          <TextBlock Text="{Binding HistoryStatus}"
                     Style="{DynamicResource Text.Status}"
                     Margin="0,4,0,0" />
        </StackPanel>
      </DockPanel>

      <UniformGrid Grid.Row="1" Columns="3" Margin="-8,12,-8,4">
        <Border Style="{DynamicResource Card.Panel}">
          <StackPanel>
            <TextBlock Text="Command Records" Style="{DynamicResource Text.CardTitle}" />
            <TextBlock Text="{Binding RecentCommands.Count}" Style="{DynamicResource Text.MetricValue}" />
          </StackPanel>
        </Border>
        <Border Style="{DynamicResource Card.Panel}">
          <StackPanel>
            <TextBlock Text="Last Refresh" Style="{DynamicResource Text.CardTitle}" />
            <TextBlock Text="{Binding LastHistoryRefreshAt, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}, TargetNullValue=-}"
                       Style="{DynamicResource Text.StatusStrong}" />
          </StackPanel>
        </Border>
        <Border Style="{DynamicResource Card.Panel}">
          <StackPanel>
            <TextBlock Text="History Source" Style="{DynamicResource Text.CardTitle}" />
            <TextBlock Text="SQLite motion_command_history"
                       Style="{DynamicResource Text.StatusStrong}"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>
      </UniformGrid>

      <Border Grid.Row="2" Style="{DynamicResource Card.Panel}" Margin="0,8,0,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <TextBlock Text="Recent Motion Commands" Style="{DynamicResource Text.CardTitle}" />
          <ListView Grid.Row="1"
                    ItemsSource="{Binding RecentCommands}"
                    Background="{DynamicResource Brush.PanelAlt}"
                    BorderThickness="0"
                    Foreground="{DynamicResource Brush.TextPrimary}">
            <ListView.View>
              <GridView>
                <GridViewColumn Header="Time" DisplayMemberBinding="{Binding CreatedAtText}" Width="150" />
                <GridViewColumn Header="Command" DisplayMemberBinding="{Binding CommandName}" Width="130" />
                <GridViewColumn Header="Axis" DisplayMemberBinding="{Binding AxisId}" Width="60" />
                <GridViewColumn Header="Status" DisplayMemberBinding="{Binding StatusText}" Width="90" />
                <GridViewColumn Header="Error" DisplayMemberBinding="{Binding ErrorCode}" Width="86" />
                <GridViewColumn Header="Elapsed" DisplayMemberBinding="{Binding ElapsedText}" Width="86" />
                <GridViewColumn Header="Correlation" DisplayMemberBinding="{Binding CorrelationShort}" Width="110" />
                <GridViewColumn Header="Message" DisplayMemberBinding="{Binding Message}" Width="360" />
              </GridView>
            </ListView.View>
          </ListView>
        </Grid>
      </Border>
    </Grid>
  </ScrollViewer>
</UserControl>
