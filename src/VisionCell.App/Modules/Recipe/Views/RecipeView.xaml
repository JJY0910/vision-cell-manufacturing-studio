<UserControl x:Class="VisionCell.App.Modules.Recipe.Views.RecipeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:VisionCell.App.Shared.Controls">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <DockPanel>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
          <Button Content="Set Active"
                  Command="{Binding ActivateRecipeCommand}"
                  ToolTip="Set the selected indexed recipe as the active recipe."
                  Height="36"
                  MinWidth="112"
                  Margin="0,0,8,0" />
          <Button Content="Refresh Index"
                  Command="{Binding RefreshCommand}"
                  ToolTip="Reload the local SQLite recipe index."
                  Height="36"
                  MinWidth="132" />
        </StackPanel>
        <StackPanel>
          <TextBlock Text="Recipe" Style="{DynamicResource Text.PageTitle}" />
          <TextBlock Text="{Binding StatusText}"
                     Style="{DynamicResource Text.Status}"
                     Margin="0,4,0,0" />
        </StackPanel>
      </DockPanel>

      <UniformGrid Grid.Row="1" Columns="4" Margin="-8,12,-8,4">
        <controls:KpiCard Title="Indexed Recipes"
                          Value="{Binding Recipes.Count}"
                          Detail="SQLite recipe index rows" />
        <controls:KpiCard Title="Validation"
                          Value="{Binding ValidRecipeCount, StringFormat={}{0} valid}"
                          Detail="{Binding InvalidRecipeCount, StringFormat={}{0} invalid}" />
        <controls:KpiCard Title="Active Recipe"
                          Value="{Binding ActiveRecipeText}"
                          Detail="{Binding ActiveRecipeCount, StringFormat={}{0} active rows}" />
        <controls:KpiCard Title="Last Refresh"
                          Value="{Binding LastRefreshText}"
                          Detail="{Binding StatusText}" />
      </UniformGrid>

      <Border Grid.Row="2" Style="{DynamicResource Card.Panel}" Margin="0,8,0,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <DockPanel>
            <Button DockPanel.Dock="Right"
                    Content="Save Recipe"
                    Command="{Binding SaveRecipeCommand}"
                    ToolTip="Validate, save, and index the recipe editor values."
                    Height="32"
                    MinWidth="112" />
            <TextBlock Text="Recipe Editor" Style="{DynamicResource Text.CardTitle}" />
          </DockPanel>

          <WrapPanel Grid.Row="1" Margin="0,4,0,0">
            <StackPanel Width="180" Margin="0,0,12,8">
              <TextBlock Text="Recipe ID" Style="{DynamicResource Text.MetricLabel}" />
              <TextBox Text="{Binding RecipeIdText, UpdateSourceTrigger=PropertyChanged}"
                       Style="{DynamicResource TextBox.HmiInput}" />
            </StackPanel>
            <StackPanel Width="220" Margin="0,0,12,8">
              <TextBlock Text="Product Name" Style="{DynamicResource Text.MetricLabel}" />
              <TextBox Text="{Binding ProductNameText, UpdateSourceTrigger=PropertyChanged}"
                       Style="{DynamicResource TextBox.HmiInput}" />
            </StackPanel>
            <StackPanel Width="110" Margin="0,0,12,8">
              <TextBlock Text="Version" Style="{DynamicResource Text.MetricLabel}" />
              <TextBox Text="{Binding VersionText, UpdateSourceTrigger=PropertyChanged}"
                       Style="{DynamicResource TextBox.HmiInput}" />
            </StackPanel>
            <StackPanel Width="120" Margin="0,0,12,8">
              <TextBlock Text="Exposure ms" Style="{DynamicResource Text.MetricLabel}" />
              <TextBox Text="{Binding CameraExposureText, UpdateSourceTrigger=PropertyChanged}"
                       Style="{DynamicResource TextBox.HmiInput}" />
            </StackPanel>
            <StackPanel Width="96" Margin="0,0,12,8">
              <TextBlock Text="Gain" Style="{DynamicResource Text.MetricLabel}" />
              <TextBox Text="{Binding CameraGainText, UpdateSourceTrigger=PropertyChanged}"
                       Style="{DynamicResource TextBox.HmiInput}" />
            </StackPanel>
            <StackPanel Width="96" Margin="0,0,12,8">
              <TextBlock Text="Light" Style="{DynamicResource Text.MetricLabel}" />
              <TextBox Text="{Binding CameraLightText, UpdateSourceTrigger=PropertyChanged}"
                       Style="{DynamicResource TextBox.HmiInput}" />
            </StackPanel>
          </WrapPanel>

          <WrapPanel Grid.Row="2" Margin="0,4,0,0">
            <StackPanel Width="150" Margin="0,0,12,8">
              <TextBlock Text="Teaching ID" Style="{DynamicResource Text.MetricLabel}" />
              <TextBox Text="{Binding TeachingPointIdText, UpdateSourceTrigger=PropertyChanged}"
                       Style="{DynamicResource TextBox.HmiInput}" />
            </StackPanel>
            <StackPanel Width="190" Margin="0,0,12,8">
              <TextBlock Text="Teaching Name" Style="{DynamicResource Text.MetricLabel}" />
              <TextBox Text="{Binding TeachingPointNameText, UpdateSourceTrigger=PropertyChanged}"
                       Style="{DynamicResource TextBox.HmiInput}" />
            </StackPanel>
            <StackPanel Width="84" Margin="0,0,12,8">
              <TextBlock Text="X" Style="{DynamicResource Text.MetricLabel}" />
              <TextBox Text="{Binding TeachingXText, UpdateSourceTrigger=PropertyChanged}"
                       Style="{DynamicResource TextBox.HmiInput}" />
            </StackPanel>
            <StackPanel Width="84" Margin="0,0,12,8">
              <TextBlock Text="Y" Style="{DynamicResource Text.MetricLabel}" />
              <TextBox Text="{Binding TeachingYText, UpdateSourceTrigger=PropertyChanged}"
                       Style="{DynamicResource TextBox.HmiInput}" />
            </StackPanel>
            <StackPanel Width="84" Margin="0,0,12,8">
              <TextBlock Text="Z" Style="{DynamicResource Text.MetricLabel}" />
              <TextBox Text="{Binding TeachingZText, UpdateSourceTrigger=PropertyChanged}"
                       Style="{DynamicResource TextBox.HmiInput}" />
            </StackPanel>
            <StackPanel Width="84" Margin="0,0,12,8">
              <TextBlock Text="Theta" Style="{DynamicResource Text.MetricLabel}" />
              <TextBox Text="{Binding TeachingThetaText, UpdateSourceTrigger=PropertyChanged}"
                       Style="{DynamicResource TextBox.HmiInput}" />
            </StackPanel>
          </WrapPanel>

          <WrapPanel Grid.Row="3" Margin="0,4,0,0">
            <StackPanel Width="120" Margin="0,0,12,8">
              <TextBlock Text="ROI ID" Style="{DynamicResource Text.MetricLabel}" />
              <TextBox Text="{Binding RoiIdText, UpdateSourceTrigger=PropertyChanged}"
                       Style="{DynamicResource TextBox.HmiInput}" />
            </StackPanel>
            <StackPanel Width="160" Margin="0,0,12,8">
              <TextBlock Text="ROI Name" Style="{DynamicResource Text.MetricLabel}" />
              <TextBox Text="{Binding RoiNameText, UpdateSourceTrigger=PropertyChanged}"
                       Style="{DynamicResource TextBox.HmiInput}" />
            </StackPanel>
            <StackPanel Width="76" Margin="0,0,12,8">
              <TextBlock Text="ROI X" Style="{DynamicResource Text.MetricLabel}" />
              <TextBox Text="{Binding RoiXText, UpdateSourceTrigger=PropertyChanged}"
                       Style="{DynamicResource TextBox.HmiInput}" />
            </StackPanel>
            <StackPanel Width="76" Margin="0,0,12,8">
              <TextBlock Text="ROI Y" Style="{DynamicResource Text.MetricLabel}" />
              <TextBox Text="{Binding RoiYText, UpdateSourceTrigger=PropertyChanged}"
                       Style="{DynamicResource TextBox.HmiInput}" />
            </StackPanel>
            <StackPanel Width="76" Margin="0,0,12,8">
              <TextBlock Text="Width" Style="{DynamicResource Text.MetricLabel}" />
              <TextBox Text="{Binding RoiWidthText, UpdateSourceTrigger=PropertyChanged}"
                       Style="{DynamicResource TextBox.HmiInput}" />
            </StackPanel>
            <StackPanel Width="76" Margin="0,0,12,8">
              <TextBlock Text="Height" Style="{DynamicResource Text.MetricLabel}" />
              <TextBox Text="{Binding RoiHeightText, UpdateSourceTrigger=PropertyChanged}"
                       Style="{DynamicResource TextBox.HmiInput}" />
            </StackPanel>
          </WrapPanel>
        </Grid>
      </Border>

      <Border Grid.Row="3" Style="{DynamicResource Card.Panel}" Margin="0,8,0,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <DockPanel>
            <TextBlock Text="Recipe Index" Style="{DynamicResource Text.CardTitle}" />
            <TextBlock DockPanel.Dock="Right"
                       Text="{Binding StatusText}"
                       Style="{DynamicResource Text.Status}" />
          </DockPanel>
          <ListView Grid.Row="1"
                    ItemsSource="{Binding Recipes}"
                    SelectedItem="{Binding SelectedRecipe}"
                    MinHeight="220"
                    Style="{DynamicResource ListView.HmiGrid}">
            <ListView.View>
              <GridView>
                <GridViewColumn Header="Recipe ID" DisplayMemberBinding="{Binding RecipeId}" Width="170" />
                <GridViewColumn Header="Version" DisplayMemberBinding="{Binding Version}" Width="90" />
                <GridViewColumn Header="Product" DisplayMemberBinding="{Binding ProductName}" Width="220" />
                <GridViewColumn Header="Active" DisplayMemberBinding="{Binding ActiveText}" Width="90" />
                <GridViewColumn Header="Validation" DisplayMemberBinding="{Binding ValidationStateText}" Width="100" />
                <GridViewColumn Header="Updated" DisplayMemberBinding="{Binding UpdatedAtText}" Width="150" />
                <GridViewColumn Header="Checksum" DisplayMemberBinding="{Binding ChecksumShort}" Width="110" />
                <GridViewColumn Header="Summary" DisplayMemberBinding="{Binding ValidationSummaryText}" Width="280" />
              </GridView>
            </ListView.View>
          </ListView>
        </Grid>
      </Border>

      <Border Grid.Row="4" Style="{DynamicResource Card.Panel}" Margin="0,8,0,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <TextBlock Text="Selected Recipe Detail" Style="{DynamicResource Text.CardTitle}" />
          <UniformGrid Grid.Row="1" Columns="4">
            <StackPanel Margin="0,0,16,8">
              <TextBlock Text="Recipe" Style="{DynamicResource Text.MetricLabel}" />
              <TextBlock Text="{Binding SelectedRecipe.RecipeId, TargetNullValue=-}"
                         Style="{DynamicResource Text.StatusStrong}"
                         TextWrapping="Wrap" />
            </StackPanel>
            <StackPanel Margin="0,0,16,8">
              <TextBlock Text="Version" Style="{DynamicResource Text.MetricLabel}" />
              <TextBlock Text="{Binding SelectedRecipe.Version, TargetNullValue=-}"
                         Style="{DynamicResource Text.StatusStrong}" />
            </StackPanel>
            <StackPanel Margin="0,0,16,8">
              <TextBlock Text="Product" Style="{DynamicResource Text.MetricLabel}" />
              <TextBlock Text="{Binding SelectedRecipe.ProductName, TargetNullValue=-}"
                         Style="{DynamicResource Text.StatusStrong}"
                         TextWrapping="Wrap" />
            </StackPanel>
            <StackPanel Margin="0,0,0,8">
              <TextBlock Text="Created" Style="{DynamicResource Text.MetricLabel}" />
              <TextBlock Text="{Binding SelectedRecipe.CreatedAtText, TargetNullValue=-}"
                         Style="{DynamicResource Text.StatusStrong}" />
            </StackPanel>
          </UniformGrid>
          <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Text="{Binding SelectedRecipe.DocumentPath, StringFormat=Document: {0}, TargetNullValue=Document: -}"
                       Style="{DynamicResource Text.Status}"
                       TextWrapping="Wrap" />
            <TextBlock Grid.Row="1"
                       Text="{Binding SelectedRecipe.Checksum, StringFormat=Checksum: {0}, TargetNullValue=Checksum: -}"
                       Style="{DynamicResource Text.Status}"
                       TextWrapping="Wrap"
                       Margin="0,4,0,0" />
            <TextBlock Grid.Row="2"
                       Text="{Binding SelectedRecipe.ValidationSummaryText, StringFormat=Validation: {0}, TargetNullValue=Validation: -}"
                       Style="{DynamicResource Text.Status}"
                       TextWrapping="Wrap"
                       Margin="0,4,0,0" />
          </Grid>
        </Grid>
      </Border>
    </Grid>
  </ScrollViewer>
</UserControl>
