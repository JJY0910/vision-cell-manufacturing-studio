<UserControl x:Class="VisionCell.App.Modules.Recipe.Views.RecipeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <DockPanel>
        <Button DockPanel.Dock="Right"
                Content="Refresh Index"
                Command="{Binding RefreshCommand}"
                Height="36"
                MinWidth="132" />
        <StackPanel>
          <TextBlock Text="Recipe" Style="{DynamicResource Text.PageTitle}" />
          <TextBlock Text="{Binding StatusText}"
                     Style="{DynamicResource Text.Status}"
                     Margin="0,4,0,0" />
        </StackPanel>
      </DockPanel>

      <UniformGrid Grid.Row="1" Columns="4" Margin="-8,12,-8,4">
        <Border Style="{DynamicResource Card.Panel}">
          <StackPanel>
            <TextBlock Text="Indexed Recipes" Style="{DynamicResource Text.CardTitle}" />
            <TextBlock Text="{Binding Recipes.Count}" Style="{DynamicResource Text.MetricValue}" />
          </StackPanel>
        </Border>
        <Border Style="{DynamicResource Card.Panel}">
          <StackPanel>
            <TextBlock Text="Validation" Style="{DynamicResource Text.CardTitle}" />
            <TextBlock Text="{Binding ValidRecipeCount, StringFormat={}{0} valid}"
                       Style="{DynamicResource Text.MetricValue}" />
            <TextBlock Text="{Binding InvalidRecipeCount, StringFormat={}{0} invalid}"
                       Style="{DynamicResource Text.Status}" />
          </StackPanel>
        </Border>
        <Border Style="{DynamicResource Card.Panel}">
          <StackPanel>
            <TextBlock Text="Active Recipe" Style="{DynamicResource Text.CardTitle}" />
            <TextBlock Text="{Binding ActiveRecipeText}"
                       Style="{DynamicResource Text.MetricValue}"
                       TextWrapping="Wrap" />
            <TextBlock Text="{Binding ActiveRecipeCount, StringFormat={}{0} active rows}"
                       Style="{DynamicResource Text.Status}" />
          </StackPanel>
        </Border>
        <Border Style="{DynamicResource Card.Panel}">
          <StackPanel>
            <TextBlock Text="Last Refresh" Style="{DynamicResource Text.CardTitle}" />
            <TextBlock Text="{Binding LastRefreshText}"
                       Style="{DynamicResource Text.MetricValue}"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>
      </UniformGrid>

      <Border Grid.Row="2" Style="{DynamicResource Card.Panel}" Margin="0,8,0,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <DockPanel>
            <TextBlock Text="Recipe Index" Style="{DynamicResource Text.CardTitle}" />
            <TextBlock DockPanel.Dock="Right"
                       Text="{Binding StatusText}"
                       Style="{DynamicResource Text.Status}" />
          </DockPanel>
          <ListView Grid.Row="1"
                    ItemsSource="{Binding Recipes}"
                    SelectedItem="{Binding SelectedRecipe}"
                    MinHeight="220"
                    Background="{DynamicResource Brush.PanelAlt}"
                    BorderThickness="0"
                    Foreground="{DynamicResource Brush.TextPrimary}">
            <ListView.View>
              <GridView>
                <GridViewColumn Header="Recipe ID" DisplayMemberBinding="{Binding RecipeId}" Width="170" />
                <GridViewColumn Header="Version" DisplayMemberBinding="{Binding Version}" Width="90" />
                <GridViewColumn Header="Product" DisplayMemberBinding="{Binding ProductName}" Width="220" />
                <GridViewColumn Header="Active" DisplayMemberBinding="{Binding ActiveText}" Width="90" />
                <GridViewColumn Header="Validation" DisplayMemberBinding="{Binding ValidationStateText}" Width="100" />
                <GridViewColumn Header="Updated" DisplayMemberBinding="{Binding UpdatedAtText}" Width="150" />
                <GridViewColumn Header="Checksum" DisplayMemberBinding="{Binding ChecksumShort}" Width="110" />
                <GridViewColumn Header="Summary" DisplayMemberBinding="{Binding ValidationSummaryText}" Width="280" />
              </GridView>
            </ListView.View>
          </ListView>
        </Grid>
      </Border>

      <Border Grid.Row="3" Style="{DynamicResource Card.Panel}" Margin="0,8,0,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <TextBlock Text="Selected Recipe Detail" Style="{DynamicResource Text.CardTitle}" />
          <UniformGrid Grid.Row="1" Columns="4">
            <StackPanel Margin="0,0,16,8">
              <TextBlock Text="Recipe" Style="{DynamicResource Text.MetricLabel}" />
              <TextBlock Text="{Binding SelectedRecipe.RecipeId, TargetNullValue=-}"
                         Style="{DynamicResource Text.StatusStrong}"
                         TextWrapping="Wrap" />
            </StackPanel>
            <StackPanel Margin="0,0,16,8">
              <TextBlock Text="Version" Style="{DynamicResource Text.MetricLabel}" />
              <TextBlock Text="{Binding SelectedRecipe.Version, TargetNullValue=-}"
                         Style="{DynamicResource Text.StatusStrong}" />
            </StackPanel>
            <StackPanel Margin="0,0,16,8">
              <TextBlock Text="Product" Style="{DynamicResource Text.MetricLabel}" />
              <TextBlock Text="{Binding SelectedRecipe.ProductName, TargetNullValue=-}"
                         Style="{DynamicResource Text.StatusStrong}"
                         TextWrapping="Wrap" />
            </StackPanel>
            <StackPanel Margin="0,0,0,8">
              <TextBlock Text="Created" Style="{DynamicResource Text.MetricLabel}" />
              <TextBlock Text="{Binding SelectedRecipe.CreatedAtText, TargetNullValue=-}"
                         Style="{DynamicResource Text.StatusStrong}" />
            </StackPanel>
          </UniformGrid>
          <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Text="{Binding SelectedRecipe.DocumentPath, StringFormat=Document: {0}, TargetNullValue=Document: -}"
                       Style="{DynamicResource Text.Status}"
                       TextWrapping="Wrap" />
            <TextBlock Grid.Row="1"
                       Text="{Binding SelectedRecipe.Checksum, StringFormat=Checksum: {0}, TargetNullValue=Checksum: -}"
                       Style="{DynamicResource Text.Status}"
                       TextWrapping="Wrap"
                       Margin="0,4,0,0" />
            <TextBlock Grid.Row="2"
                       Text="{Binding SelectedRecipe.ValidationSummaryText, StringFormat=Validation: {0}, TargetNullValue=Validation: -}"
                       Style="{DynamicResource Text.Status}"
                       TextWrapping="Wrap"
                       Margin="0,4,0,0" />
          </Grid>
        </Grid>
      </Border>
    </Grid>
  </ScrollViewer>
</UserControl>
