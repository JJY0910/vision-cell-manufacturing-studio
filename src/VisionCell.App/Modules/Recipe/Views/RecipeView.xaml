<UserControl x:Class="VisionCell.App.Modules.Recipe.Views.RecipeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:VisionCell.App.Shared.Controls">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <controls:CommandBar Title="Recipe"
                           StatusText="{Binding StatusText}"
                           AlertMessage="{Binding AlertMessage}"
                           HasAlert="{Binding HasAlert}">
        <controls:CommandBar.CommandContent>
          <StackPanel Orientation="Horizontal">
            <Button Content="Set Active"
                    Command="{Binding ActivateRecipeCommand}"
                    ToolTip="Set the selected indexed recipe as the active recipe."
                    Height="36"
                    MinWidth="112"
                    Margin="0,0,8,0" />
            <Button Content="Refresh Index"
                    Command="{Binding RefreshCommand}"
                    ToolTip="Reload the local SQLite recipe index."
                    Height="36"
                    MinWidth="132" />
          </StackPanel>
        </controls:CommandBar.CommandContent>
      </controls:CommandBar>

      <UniformGrid Grid.Row="1" Columns="4" Margin="-8,12,-8,4">
        <controls:KpiCard Title="Indexed Recipes"
                          Value="{Binding Recipes.Count}"
                          Detail="SQLite recipe index rows" />
        <controls:KpiCard Title="Validation"
                          Value="{Binding ValidRecipeCount, StringFormat={}{0} valid}"
                          Detail="{Binding InvalidRecipeCount, StringFormat={}{0} invalid}" />
        <controls:KpiCard Title="Active Recipe"
                          Value="{Binding ActiveRecipeText}"
                          Detail="{Binding ActiveRecipeCount, StringFormat={}{0} active rows}" />
        <controls:KpiCard Title="Last Refresh"
                          Value="{Binding LastRefreshText}"
                          Detail="{Binding StatusText}" />
      </UniformGrid>

      <Border Grid.Row="2" Style="{DynamicResource Card.Panel}" Margin="0,8,0,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <DockPanel>
            <Button DockPanel.Dock="Right"
                    Content="Save Recipe"
                    Command="{Binding SaveRecipeCommand}"
                    ToolTip="Validate, save, and index the recipe editor values."
                    Height="32"
                    MinWidth="112" />
            <TextBlock Text="Recipe Editor" Style="{DynamicResource Text.CardTitle}" />
          </DockPanel>

          <WrapPanel Grid.Row="1" Margin="0,4,0,0">
            <controls:RecipeEditorField Label="Recipe ID"
                                        Text="{Binding RecipeIdText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        FieldWidth="180"
                                        HelpText="Recipe identifier saved through the Application recipe library."
                                        Margin="0,0,12,8" />
            <controls:RecipeEditorField Label="Product Name"
                                        Text="{Binding ProductNameText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        FieldWidth="220"
                                        HelpText="Operator-facing product name for the recipe index."
                                        Margin="0,0,12,8" />
            <controls:RecipeEditorField Label="Version"
                                        Text="{Binding VersionText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        FieldWidth="110"
                                        HelpText="Recipe version written to the JSON document and SQLite index."
                                        Margin="0,0,12,8" />
            <controls:RecipeEditorField Label="Exposure ms"
                                        Text="{Binding CameraExposureText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        FieldWidth="120"
                                        HelpText="Virtual camera exposure in milliseconds."
                                        Margin="0,0,12,8" />
            <controls:RecipeEditorField Label="Gain"
                                        Text="{Binding CameraGainText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        FieldWidth="96"
                                        HelpText="Virtual camera gain used by the recipe camera settings."
                                        Margin="0,0,12,8" />
            <controls:RecipeEditorField Label="Light"
                                        Text="{Binding CameraLightText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        FieldWidth="96"
                                        HelpText="Virtual light intensity percent."
                                        Margin="0,0,12,8" />
          </WrapPanel>

          <WrapPanel Grid.Row="2" Margin="0,4,0,0">
            <controls:RecipeEditorField Label="Teaching ID"
                                        Text="{Binding TeachingPointIdText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        FieldWidth="150"
                                        HelpText="Camera teaching point identifier saved into the recipe motion section."
                                        Margin="0,0,12,8" />
            <controls:RecipeEditorField Label="Teaching Name"
                                        Text="{Binding TeachingPointNameText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        FieldWidth="190"
                                        HelpText="Camera teaching point display name."
                                        Margin="0,0,12,8" />
            <controls:RecipeEditorField Label="X"
                                        Text="{Binding TeachingXText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        FieldWidth="84"
                                        HelpText="Camera teaching X position."
                                        Margin="0,0,12,8" />
            <controls:RecipeEditorField Label="Y"
                                        Text="{Binding TeachingYText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        FieldWidth="84"
                                        HelpText="Camera teaching Y position."
                                        Margin="0,0,12,8" />
            <controls:RecipeEditorField Label="Z"
                                        Text="{Binding TeachingZText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        FieldWidth="84"
                                        HelpText="Camera teaching Z position."
                                        Margin="0,0,12,8" />
            <controls:RecipeEditorField Label="Theta"
                                        Text="{Binding TeachingThetaText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        FieldWidth="84"
                                        HelpText="Camera teaching theta position."
                                        Margin="0,0,12,8" />
          </WrapPanel>

          <WrapPanel Grid.Row="3" Margin="0,4,0,0">
            <controls:RecipeEditorField Label="ROI ID"
                                        Text="{Binding RoiIdText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        FieldWidth="120"
                                        HelpText="ROI identifier saved into the recipe vision section."
                                        Margin="0,0,12,8" />
            <controls:RecipeEditorField Label="ROI Name"
                                        Text="{Binding RoiNameText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        FieldWidth="160"
                                        HelpText="ROI display name for operator review."
                                        Margin="0,0,12,8" />
            <controls:RecipeEditorField Label="ROI X"
                                        Text="{Binding RoiXText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        FieldWidth="76"
                                        HelpText="ROI left coordinate in image pixels."
                                        Margin="0,0,12,8" />
            <controls:RecipeEditorField Label="ROI Y"
                                        Text="{Binding RoiYText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        FieldWidth="76"
                                        HelpText="ROI top coordinate in image pixels."
                                        Margin="0,0,12,8" />
            <controls:RecipeEditorField Label="Width"
                                        Text="{Binding RoiWidthText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        FieldWidth="76"
                                        HelpText="ROI width in image pixels."
                                        Margin="0,0,12,8" />
            <controls:RecipeEditorField Label="Height"
                                        Text="{Binding RoiHeightText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        FieldWidth="76"
                                        HelpText="ROI height in image pixels."
                                        Margin="0,0,12,8" />
          </WrapPanel>
        </Grid>
      </Border>

      <Border Grid.Row="3" Style="{DynamicResource Card.Panel}" Margin="0,8,0,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <DockPanel>
            <TextBlock Text="Recipe Index" Style="{DynamicResource Text.CardTitle}" />
            <TextBlock DockPanel.Dock="Right"
                       Text="{Binding StatusText}"
                       Style="{DynamicResource Text.Status}" />
          </DockPanel>
          <ListView Grid.Row="1"
                    ItemsSource="{Binding Recipes}"
                    SelectedItem="{Binding SelectedRecipe}"
                    MinHeight="220"
                    Style="{DynamicResource ListView.HmiGrid}">
            <ListView.View>
              <GridView>
                <GridViewColumn Header="Recipe ID" DisplayMemberBinding="{Binding RecipeId}" Width="170" />
                <GridViewColumn Header="Version" DisplayMemberBinding="{Binding Version}" Width="90" />
                <GridViewColumn Header="Product" DisplayMemberBinding="{Binding ProductName}" Width="220" />
                <GridViewColumn Header="Active" DisplayMemberBinding="{Binding ActiveText}" Width="90" />
                <GridViewColumn Header="Validation" DisplayMemberBinding="{Binding ValidationStateText}" Width="100" />
                <GridViewColumn Header="Updated" DisplayMemberBinding="{Binding UpdatedAtText}" Width="150" />
                <GridViewColumn Header="Checksum" DisplayMemberBinding="{Binding ChecksumShort}" Width="110" />
                <GridViewColumn Header="Summary" DisplayMemberBinding="{Binding ValidationSummaryText}" Width="280" />
              </GridView>
            </ListView.View>
          </ListView>
        </Grid>
      </Border>

      <Border Grid.Row="4" Style="{DynamicResource Card.Panel}" Margin="0,8,0,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <TextBlock Text="Selected Recipe Detail" Style="{DynamicResource Text.CardTitle}" />
          <UniformGrid Grid.Row="1" Columns="4">
            <StackPanel Margin="0,0,16,8">
              <TextBlock Text="Recipe" Style="{DynamicResource Text.MetricLabel}" />
              <TextBlock Text="{Binding SelectedRecipe.RecipeId, TargetNullValue=-}"
                         Style="{DynamicResource Text.StatusStrong}"
                         TextWrapping="Wrap" />
            </StackPanel>
            <StackPanel Margin="0,0,16,8">
              <TextBlock Text="Version" Style="{DynamicResource Text.MetricLabel}" />
              <TextBlock Text="{Binding SelectedRecipe.Version, TargetNullValue=-}"
                         Style="{DynamicResource Text.StatusStrong}" />
            </StackPanel>
            <StackPanel Margin="0,0,16,8">
              <TextBlock Text="Product" Style="{DynamicResource Text.MetricLabel}" />
              <TextBlock Text="{Binding SelectedRecipe.ProductName, TargetNullValue=-}"
                         Style="{DynamicResource Text.StatusStrong}"
                         TextWrapping="Wrap" />
            </StackPanel>
            <StackPanel Margin="0,0,0,8">
              <TextBlock Text="Created" Style="{DynamicResource Text.MetricLabel}" />
              <TextBlock Text="{Binding SelectedRecipe.CreatedAtText, TargetNullValue=-}"
                         Style="{DynamicResource Text.StatusStrong}" />
            </StackPanel>
          </UniformGrid>
          <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Text="{Binding SelectedRecipe.DocumentPath, StringFormat=Document: {0}, TargetNullValue=Document: -}"
                       Style="{DynamicResource Text.Status}"
                       TextWrapping="Wrap" />
            <TextBlock Grid.Row="1"
                       Text="{Binding SelectedRecipe.Checksum, StringFormat=Checksum: {0}, TargetNullValue=Checksum: -}"
                       Style="{DynamicResource Text.Status}"
                       TextWrapping="Wrap"
                       Margin="0,4,0,0" />
            <TextBlock Grid.Row="2"
                       Text="{Binding SelectedRecipe.ValidationSummaryText, StringFormat=Validation: {0}, TargetNullValue=Validation: -}"
                       Style="{DynamicResource Text.Status}"
                       TextWrapping="Wrap"
                       Margin="0,4,0,0" />
          </Grid>
        </Grid>
      </Border>
    </Grid>
  </ScrollViewer>
</UserControl>
