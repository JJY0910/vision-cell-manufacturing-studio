<UserControl x:Class="VisionCell.App.Modules.Reports.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:VisionCell.App.Shared.Controls">
  <ScrollViewer VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled">
    <Grid MinWidth="0">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <controls:CommandBar Title="Reports"
                           StatusText="CSV export and lot summary remain scoped to FR-203/FR-204." />

      <Border Grid.Row="1" Style="{DynamicResource Card.Panel}" Margin="0,12,0,0">
        <controls:EmptyState HasItems="False"
                             Title="Reports Export Not Configured"
                             Detail="Use Offline Debug to review persisted inspection results until the FR-203 CSV export and FR-204 lot summary workflow is implemented." />
      </Border>
    </Grid>
  </ScrollViewer>
</UserControl>
